---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Vendors | Untouchable Smoke Shop" description="Pitch your products to Untouchable Smoke Shop. We don't stock everything. We stock the best.">
    <main class="pt-32 pb-24 px-6 max-w-4xl mx-auto min-h-[80vh] flex flex-col justify-center">
        <div class="text-center mb-16">
            <div class="inline-block bg-white/10 border border-white/20 rounded-full px-4 py-1.5 mb-6 backdrop-blur-md">
                <p class="text-bright-cyan font-bold uppercase tracking-widest text-xs">Vendor Application</p>
            </div>
            <h1 class="text-4xl md:text-6xl font-black uppercase tracking-tighter text-white mb-6 leading-tight">
                We don't stock everything. <br><span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-glow to-bright-cyan">We stock the best.</span>
            </h1>
            <p class="text-gray-300 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
                Think your product belongs on our shelves? Pitch the shop. If it hits our standards, we'll be in touch.
            </p>
        </div>

        <div class="bg-black/40 p-8 md:p-12 rounded-[2rem] border border-white/10 backdrop-blur-xl shadow-2xl relative overflow-hidden">
            <div class="glow-blur -top-20 -right-20 w-64 h-64 bg-teal-glow/20 pointer-events-none"></div>
            
            <form id="vendor-form" class="relative z-10 space-y-6" onsubmit="event.preventDefault(); /* TODO: Add fetch to Formspree here */ document.getElementById('vendor-form').classList.add('hidden'); document.getElementById('vendor-success').classList.remove('hidden');">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label for="company" class="text-sm font-bold uppercase tracking-widest text-gray-400">Company Name</label>
                        <input type="text" id="company" name="company" required class="w-full bg-white/5 border border-white/10 rounded-xl px-6 py-4 text-white focus:outline-none focus:border-bright-cyan transition-all font-medium">
                    </div>
                    <div class="space-y-2">
                        <label for="contact" class="text-sm font-bold uppercase tracking-widest text-gray-400">Contact Person</label>
                        <input type="text" id="contact" name="contact" required class="w-full bg-white/5 border border-white/10 rounded-xl px-6 py-4 text-white focus:outline-none focus:border-bright-cyan transition-all font-medium">
                    </div>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label for="email" class="text-sm font-bold uppercase tracking-widest text-gray-400">Email Address</label>
                        <input type="email" id="email" name="email" required class="w-full bg-white/5 border border-white/10 rounded-xl px-6 py-4 text-white focus:outline-none focus:border-bright-cyan transition-all font-medium">
                    </div>
                    <div class="space-y-2">
                        <label for="website" class="text-sm font-bold uppercase tracking-widest text-gray-400">Website / Catalog URL</label>
                        <input type="url" id="website" name="website" required class="w-full bg-white/5 border border-white/10 rounded-xl px-6 py-4 text-white focus:outline-none focus:border-bright-cyan transition-all font-medium">
                    </div>
                </div>

                <div class="space-y-2">
                    <label for="pitch" class="text-sm font-bold uppercase tracking-widest text-gray-400">The Pitch (Why should we stock it?)</label>
                    <textarea id="pitch" name="pitch" rows="4" required class="w-full bg-white/5 border border-white/10 rounded-xl px-6 py-4 text-white focus:outline-none focus:border-bright-cyan transition-all font-medium resize-none"></textarea>
                </div>

                <button type="submit" class="w-full vibe-gradient px-8 py-5 rounded-xl font-black text-white uppercase tracking-widest hover:scale-[1.02] active:scale-[0.98] transition-all text-lg shadow-[0_0_20px_rgba(30,149,212,0.3)] mt-4">
                    Submit Your Specs
                </button>
            </form>

            <div id="vendor-success" class="hidden text-center py-12 relative z-10">
                <i class="fa-solid fa-check-circle text-6xl text-bright-cyan mb-6"></i>
                <h3 class="text-3xl font-black uppercase tracking-tighter text-white mb-4">Specs Received</h3>
                <p class="text-gray-300 text-lg">We’ve got your info. If it hits our standards, we’ll be in touch.</p>
            </div>
        </div>
    </main>
</Layout>
