---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Untouchable Smoke Shop | Atlanta's #1 Midnight Spot" description="Untouchable Smoke Shop in Atlanta offers the best prices on vapes, glass, and accessories. Located at 533 Peachtree St NE, open late until 2 AM on weekends.">
    <!-- AGE VERIFICATION OVERLAY -->
    <div id="age-gate" class="fixed inset-0 z-[100] bg-deep-black flex items-center justify-center p-4" role="dialog" aria-modal="true" aria-labelledby="age-gate-title">
        <div class="max-w-md 3xl:max-w-xl w-full glass-morphism p-8 3xl:p-12 rounded-3xl text-center border-teal-glow/30 border-2 shadow-2xl shadow-teal-glow/10">
            <div class="text-4xl 3xl:text-6xl mb-4 text-teal-glow animate-pulse"><i class="fa-solid fa-id-card" aria-hidden="true"></i></div>
            <h2 id="age-gate-title" class="text-3xl 3xl:text-5xl font-extrabold mb-4 uppercase tracking-tighter">Identity Check</h2>
            <p class="text-gray-300 mb-8 font-medium text-sm 3xl:text-base">You must be at least 21 years old to enter. Untouchable Smoke Shop strictly verifies IDs in-store.</p>
            <div class="flex flex-col gap-4">
                <button id="verify-age-btn" class="vibe-gradient py-4 3xl:py-6 px-8 rounded-xl font-bold text-white text-lg 3xl:text-2xl transition-transform hover:scale-105 active:scale-95 shadow-lg shadow-cyan-500/20" aria-label="Confirm I am 21 or older">
                    I am 21+ Years Old
                </button>
                <button onclick="window.location.href='https://google.com'" class="text-gray-500 hover:text-white transition-colors 3xl:text-lg" aria-label="Exit because I am under 21">
                    I am under 21
                </button>
            </div>
        </div>
    </div>

    <!-- GLOBAL TRUST BANNER -->
    <div class="vibe-gradient text-white text-[10px] md:text-xs 3xl:text-sm font-black py-2 3xl:py-3 px-4 text-center sticky top-0 z-50 uppercase tracking-widest shadow-lg" role="alert">
        🔞 STRICTLY 21+ ONLY. VALID ID REQUIRED. OPEN UNTIL 2AM FRI/SAT.
    </div>

    <!-- NAVIGATION -->
    <nav class="p-6 3xl:p-10 border-b border-white/5 flex justify-between items-center bg-black/50 backdrop-blur-md sticky top-[32px] md:top-[36px] 3xl:top-[44px] z-40" role="navigation" aria-label="Main Navigation">
        <div class="flex items-center gap-2 3xl:gap-4">
            <div class="w-10 h-10 3xl:w-14 3xl:h-14 vibe-gradient rounded-lg flex items-center justify-center shadow-lg shadow-teal-glow/20">
                <i class="fa-solid fa-crown text-white text-xl 3xl:text-3xl" aria-hidden="true"></i>
            </div>
            <span class="font-extrabold text-xl 3xl:text-3xl tracking-tighter uppercase">Untouchable <span class="text-bright-cyan">Smoke</span></span>
        </div>
        <div class="hidden md:flex gap-8 3xl:gap-16 text-gray-400">
            <a href="#vapes" class="nav-link">Vapes</a>
            <a href="#glass" class="nav-link">Glass</a>
            <a href="#reviews" class="nav-link">Reviews</a>
            <a href="#location-map" class="nav-link text-bright-cyan border-b border-teal-glow">Peachtree St</a>
        </div>
        <a href="#optin" class="bg-white text-black py-2.5 px-6 3xl:px-10 rounded-full text-[10px] 3xl:text-sm font-black hover:bg-bright-cyan hover:text-white transition-all uppercase tracking-widest" aria-label="Get 10% discount">Get 10% Off</a>
    </nav>

    <!-- HERO SECTION -->
    <header class="relative py-24 md:py-32 3xl:py-56 px-6 max-w-[2000px] mx-auto text-center overflow-hidden">
        <div class="glow-blur -top-20 -left-20 w-80 h-80 3xl:w-[600px] 3xl:h-[600px] bg-olive-glow animate-float"></div>
        <div class="glow-blur top-40 -right-20 w-96 h-96 3xl:w-[800px] 3xl:h-[800px] bg-green-glow opacity-10"></div>
        
        <h1 class="hero-title">
            UNTOUCHABLE <br><span class="text-gradient">PRICES.</span>
        </h1>
        <p class="text-lg md:text-xl 3xl:text-3xl text-gray-300 max-w-2xl 3xl:max-w-5xl mx-auto mb-10 3xl:mb-20 font-medium leading-relaxed">
            Atlanta’s best prices, guaranteed. Open late every night on Peachtree St for all your vape, glass, and accessory needs.
        </p>
        <div class="flex flex-wrap justify-center gap-4 3xl:gap-8">
            <a href="#optin" class="vibe-gradient px-10 py-5 3xl:px-16 3xl:py-8 rounded-full font-black text-white text-lg 3xl:text-2xl hover:shadow-cyan-500/30 shadow-xl transition-all hover:-translate-y-1">CLAIM YOUR 10% CODE</a>
            <a href="#location-map" class="glass-morphism px-10 py-5 3xl:px-16 3xl:py-8 rounded-full font-black text-lg 3xl:text-2xl border border-white/10 uppercase tracking-wider hover:bg-white/5 transition-all">Visit Us Now</a>
        </div>
    </header>

    <!-- STATS -->
    <section class="max-w-[1800px] mx-auto px-6 grid grid-cols-2 lg:grid-cols-4 gap-4 3xl:gap-8 mb-20 3xl:mb-40 relative">
        <div class="glass-morphism p-6 3xl:p-12 rounded-2xl text-center border-t border-white/5 hover:border-teal-glow/30">
            <div class="text-3xl 3xl:text-6xl font-black text-bright-cyan mb-1">5.0</div>
            <div class="text-[10px] 3xl:text-sm text-gray-500 uppercase font-bold tracking-widest">Google Rating</div>
        </div>
        <div class="glass-morphism p-6 3xl:p-12 rounded-2xl text-center border-t border-white/5 hover:border-teal-glow/30">
            <div class="text-3xl 3xl:text-6xl font-black text-teal-glow mb-1">2AM</div>
            <div class="text-[10px] 3xl:text-sm text-gray-500 uppercase font-bold tracking-widest">Fri/Sat Close</div>
        </div>
        <div class="glass-morphism p-6 3xl:p-12 rounded-2xl text-center border-t border-white/5 hover:border-teal-glow/30">
            <div class="text-3xl 3xl:text-6xl font-black text-electric-blue mb-1">100%</div>
            <div class="text-[10px] 3xl:text-sm text-gray-500 uppercase font-bold tracking-widest">Authentic Gear</div>
        </div>
        <div class="glass-morphism p-6 3xl:p-12 rounded-2xl text-center border-t border-white/5 hover:border-teal-glow/30">
            <div class="text-3xl 3xl:text-6xl font-black text-white mb-1">ATL</div>
            <div class="text-[10px] 3xl:text-sm text-gray-500 uppercase font-bold tracking-widest">Best Selection</div>
        </div>
    </section>

    <!-- INVENTORY -->
    <section id="vapes" class="py-20 3xl:py-40 px-6 max-w-[1800px] mx-auto">
        <div class="flex justify-between items-end mb-12 3xl:mb-24">
            <div>
                <h2 class="text-4xl 3xl:text-7xl font-black tracking-tighter mb-2 uppercase italic">Inventory Drop</h2>
                <p class="text-gray-300 3xl:text-2xl">Premium hardware at 533 Peachtree.</p>
            </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 3xl:gap-12">
            <article class="bg-charcoal rounded-3xl p-8 3xl:p-16 border-t-2 border-teal-glow hover:bg-black transition-all hover:scale-[1.02] cursor-default group">
                <div class="text-teal-glow text-3xl 3xl:text-5xl mb-6 group-hover:scale-110 transition-transform"><i class="fa-solid fa-bolt"></i></div>
                <h3 class="text-2xl 3xl:text-4xl font-black mb-2 uppercase">Vapes & Disposables</h3>
                <p class="text-gray-300 text-sm 3xl:text-xl mb-6 leading-relaxed">Geek Bar Pulse, Lost Mary, Raz, and more. We stock the newest flavors before anyone else downtown.</p>
                <div class="text-xs 3xl:text-sm font-black text-teal-glow uppercase tracking-widest">Authorized Dealer</div>
            </article>

            <article id="glass" class="bg-charcoal rounded-3xl p-8 3xl:p-16 border-t-2 border-bright-cyan hover:bg-black transition-all hover:scale-[1.02] cursor-default group">
                <div class="text-bright-cyan text-3xl 3xl:text-5xl mb-6 group-hover:scale-110 transition-transform"><i class="fa-solid fa-fire"></i></div>
                <h3 class="text-2xl 3xl:text-4xl font-black mb-2 uppercase">Premium Glass</h3>
                <p class="text-gray-300 text-sm 3xl:text-xl mb-6 leading-relaxed">Scientific rigs, artisan beakers, and travel pieces. High quality without the Midtown price hike.</p>
                <div class="text-xs 3xl:text-sm font-black text-bright-cyan uppercase tracking-widest">New Arrivals Daily</div>
            </article>

            <article class="bg-charcoal rounded-3xl p-8 3xl:p-16 border-t-2 border-electric-blue hover:bg-black transition-all hover:scale-[1.02] cursor-default group">
                <div class="text-electric-blue text-3xl 3xl:text-5xl mb-6 group-hover:scale-110 transition-transform"><i class="fa-solid fa-gem"></i></div>
                <h3 class="text-2xl 3xl:text-4xl font-black mb-2 uppercase">Accessories</h3>
                <p class="text-gray-300 text-sm 3xl:text-xl mb-6 leading-relaxed">Raw papers, luxury grinders, and cleaning supplies. Everything you need for the ultimate session.</p>
                <div class="text-xs 3xl:text-sm font-black text-electric-blue uppercase tracking-widest">Wholesale Prices</div>
            </article>
        </div>
    </section>

    <!-- MAP SECTION -->
    <section id="location-map" class="py-20 3xl:py-40 px-6 max-w-[1800px] mx-auto overflow-hidden">
        <div class="grid lg:grid-cols-2 gap-12 3xl:gap-24 items-center">
            <div class="space-y-8">
                <h2 class="text-4xl 3xl:text-7xl font-black tracking-tighter uppercase italic">
                    Pull Up to <span class="text-bright-cyan">Peachtree</span>
                </h2>
                <p class="text-gray-300 3xl:text-2xl font-medium leading-relaxed max-w-xl">
                    Located in the heart of Atlanta. Look for the neon glow at 533 Peachtree St NE. We're the midnight destination for the city's premium smoke needs.
                </p>
                <div class="flex flex-col gap-4">
                    <a href="https://maps.app.goo.gl/DBnPu5MiW5beXzQg4" target="_blank" class="vibe-gradient px-8 py-5 rounded-2xl font-black text-white text-center hover:scale-105 transition-all shadow-lg flex items-center justify-center gap-3 text-lg 3xl:text-2xl">
                        <i class="fa-solid fa-diamond-turn-right"></i> GET DIRECTIONS
                    </a>
                    <div class="flex gap-4 items-center text-gray-400 font-bold uppercase tracking-widest text-xs 3xl:text-lg">
                        <i class="fa-solid fa-clock text-teal-glow"></i> Open until Midnight (2AM Weekends)
                    </div>
                </div>
            </div>

            <div class="relative aspect-video lg:aspect-square rounded-[40px] overflow-hidden border border-white/10 shadow-2xl shadow-teal-glow/5">
                <iframe 
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3316.8290263673757!2d-84.38883622415664!3d33.76949397326514!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x88f5047b744d21f3%3A0xe67d60505b380b2a!2sUntouchable%20Smoke%20Shop!5e0!3m2!1sen!2sus!4v1711660000000!5m2!1sen!2sus" 
                    width="100%" 
                    height="100%" 
                    style="border:0;" 
                    allowfullscreen="" 
                    loading="lazy" 
                    referrerpolicy="no-referrer-when-downgrade"
                    class="map-frame"
                    title="Google Maps location of Untouchable Smoke Shop">
                </iframe>
            </div>
        </div>
    </section>

    <!-- REVIEWS -->
    <section id="reviews" class="bg-charcoal/30 py-24 3xl:py-48 px-6 relative">
        <div class="glow-blur absolute inset-0 bg-olive-glow opacity-5 animate-pulse-slow"></div>
        <div class="max-w-[1800px] mx-auto relative z-10">
            <h2 class="text-4xl 3xl:text-7xl font-black tracking-tighter mb-12 3xl:mb-24 uppercase text-center italic">Trusted by the <span class="text-bright-cyan">City</span></h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 3xl:gap-12">
                <figure class="glass-morphism p-6 3xl:p-12 rounded-2xl hover:-translate-y-2">
                    <div class="flex text-teal-glow mb-4 text-xs 3xl:text-lg"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                    <blockquote class="text-sm 3xl:text-xl italic mb-4 text-gray-300">"Hikeen is so sweet and very attentive! They’re so friendly and have amazing prices!"</blockquote>
                    <figcaption class="text-xs 3xl:text-sm font-bold uppercase tracking-widest text-bright-cyan">— Jaden Droge</figcaption>
                </figure>
                <figure class="glass-morphism p-6 3xl:p-12 rounded-2xl border-bright-cyan/20 hover:-translate-y-2">
                    <div class="flex text-bright-cyan mb-4 text-xs 3xl:text-lg"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                    <blockquote class="text-sm 3xl:text-xl italic mb-4 text-gray-300">"BEST PRICES IN ATLANTA THANKS FOR THE BEST PRICES. Very clean and amazing atmosphere!!"</blockquote>
                    <figcaption class="text-xs 3xl:text-sm font-bold uppercase tracking-widest text-bright-cyan">— Tyreak Muhammad</figcaption>
                </figure>
                <figure class="glass-morphism p-6 3xl:p-12 rounded-2xl hover:-translate-y-2">
                    <div class="flex text-teal-glow mb-4 text-xs 3xl:text-lg"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                    <blockquote class="text-sm 3xl:text-xl italic mb-4 text-gray-300">"Customer Service was very embracing I will continue to Shop due to reasonable prices."</blockquote>
                    <figcaption class="text-xs 3xl:text-sm font-bold uppercase tracking-widest text-bright-cyan">— Thomas Scott</figcaption>
                </figure>
            </div>
        </div>
    </section>

    <!-- SMS OPT-IN -->
    <section id="optin" class="py-32 3xl:py-64 px-6">
        <div class="max-w-4xl 3xl:max-w-7xl mx-auto vibe-gradient p-[1px] rounded-[40px] shadow-2xl shadow-cyan-500/20">
            <div class="bg-deep-black rounded-[39px] p-8 md:p-16 3xl:p-32 text-center relative overflow-hidden">
                <div class="glow-blur -bottom-20 -left-20 w-64 h-64 3xl:w-[600px] 3xl:h-[600px] bg-bright-cyan !opacity-10"></div>
                <h2 class="text-4xl md:text-6xl 3xl:text-8xl font-black tracking-tighter mb-6 uppercase">Get the <span class="text-bright-cyan">VIP</span> Connection.</h2>
                <p class="text-lg 3xl:text-3xl text-gray-300 mb-10 3xl:mb-20 font-medium">Be the first to know about new glass drops and flash sales. Plus, 10% off your next visit.</p>
                <form id="sms-form" class="max-w-md 3xl:max-w-2xl mx-auto space-y-4 relative z-10">
                    <div class="visually-hidden-hp" aria-hidden="true">
                        <label for="hp_full_name">Full Name</label>
                        <input type="text" id="hp_full_name" name="hp_full_name" tabindex="-1" autocomplete="off">
                    </div>
                    <div class="flex flex-col md:flex-row gap-4 relative">
                        <input type="tel" id="phone-input" placeholder="Mobile Number" required class="flex-1 bg-white/5 border border-white/10 rounded-2xl px-6 py-4 3xl:py-8 3xl:px-10 text-white 3xl:text-2xl focus:outline-none focus:border-teal-glow transition-all placeholder:text-gray-600 font-bold tracking-widest">
                        <button type="submit" id="submit-btn" class="vibe-gradient px-8 py-4 3xl:px-12 3xl:py-8 rounded-2xl font-black text-white 3xl:text-2xl whitespace-nowrap hover:scale-105 active:scale-95 transition-all shadow-lg flex items-center justify-center min-w-[140px]">
                            <span id="btn-text">SIGN ME UP</span>
                            <i id="btn-spinner" class="fa-solid fa-circle-notch fa-spin hidden"></i>
                        </button>
                    </div>
                    <p id="error-message" class="text-[10px] 3xl:text-sm text-red-500 font-bold uppercase tracking-widest hidden text-center">Please enter a valid 10-digit phone number.</p>
                    <p class="text-[10px] 3xl:text-sm text-gray-500 text-center uppercase tracking-widest font-bold">21+ Only. Msg/Data rates apply.</p>
                </form>
                <div id="success-message" class="hidden mt-8 text-teal-glow font-black text-xl 3xl:text-4xl animate-bounce italic tracking-widest">WELCOME. CHECK YOUR TEXTS.</div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="border-t border-white/5 pt-20 3xl:pt-40 pb-10 px-6 bg-deep-black relative">
        <div class="glow-blur bottom-0 right-0 w-64 h-64 3xl:w-[600px] 3xl:h-[600px] bg-green-glow !opacity-10"></div>
        <div class="max-w-[1800px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 3xl:gap-24 mb-20 relative z-10">
            <div>
                <div class="flex items-center gap-2 mb-6">
                    <div class="w-8 h-8 3xl:w-12 3xl:h-12 vibe-gradient rounded-md flex items-center justify-center">
                        <i class="fa-solid fa-crown text-white text-sm 3xl:text-xl"></i>
                    </div>
                    <span class="font-extrabold text-xl 3xl:text-3xl tracking-tighter uppercase">UNTOUCHABLE</span>
                </div>
                <p class="text-gray-500 mb-6 font-medium text-sm 3xl:text-xl leading-relaxed">Downtown Atlanta's top-rated destination for smoking accessories, vapes, and high-end glass.</p>
                <div class="flex gap-6 text-xl 3xl:text-3xl text-gray-600">
                    <a href="https://www.instagram.com/untouchablesmoke533/" class="hover:text-bright-cyan transition-colors" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                    <a href="https://www.yelp.com/biz/untouchable-smoke-shop-atlanta" class="hover:text-bright-cyan transition-colors" aria-label="Yelp"><i class="fa-brands fa-yelp"></i></a>
                    <a href="https://share.google/DBnPu5MiW5beXzQg4" class="hover:text-bright-cyan transition-colors" aria-label="Google"><i class="fa-brands fa-google"></i></a>
                </div>
            </div>
            <div>
                <h4 class="font-black mb-6 text-white uppercase tracking-widest text-xs 3xl:text-base">Hours of Operation</h4>
                <ul class="space-y-3 text-sm 3xl:text-xl text-gray-300 font-bold uppercase tracking-tight">
                    <li class="flex justify-between"><span>Mon - Thu</span> <span class="text-gray-500">10AM - 12AM</span></li>
                    <li class="flex justify-between text-bright-cyan"><span>Fri - Sat</span> <span class="font-black">10AM - 2AM</span></li>
                    <li class="flex justify-between"><span>Sunday</span> <span class="text-gray-500">10AM - 12AM</span></li>
                </ul>
            </div>
            <div>
                <h4 class="font-black mb-6 text-white uppercase tracking-widest text-xs 3xl:text-base">Contact Us</h4>
                <ul class="space-y-4 text-sm 3xl:text-xl text-gray-300 font-medium">
                    <li class="flex items-start gap-3">
                        <i class="fa-solid fa-location-dot mt-1 text-teal-glow"></i>
                        <span>533 Peachtree St NE unit b<br>Atlanta, GA 30308</span>
                    </li>
                    <li class="flex items-center gap-3">
                        <i class="fa-solid fa-phone text-teal-glow"></i>
                        <a href="tel:4708736088" class="hover:text-bright-cyan transition-colors font-bold">(470) 873-6088</a>
                    </li>
                    <li class="flex items-center gap-3">
                        <i class="fa-solid fa-envelope text-teal-glow"></i>
                        <a href="mailto:untouchablesmoke533@gmail.com" class="hover:text-bright-cyan transition-colors">Email Us</a>
                    </li>
                </ul>
            </div>
        </div>
        <div class="max-w-[1800px] mx-auto pt-10 border-t border-white/5 text-center text-[10px] 3xl:text-sm text-gray-600 font-bold uppercase tracking-widest">
            <p>&copy; 2024 Untouchable Smoke Shop. Powered by <a href="https://www.sayitaintseo.com" target="_blank" rel="noopener" class="text-gray-400 hover:text-bright-cyan transition-colors underline underline-offset-4 decoration-teal-glow/30">Say It Ain't SEO</a>.</p>
        </div>
    </footer>

    <script>
        const STORE_CONFIG = {
            id: 'untouchable_v9_standard_map',
            phone: '4708736088'
        };

        function verifyAge() {
            const gate = document.getElementById('age-gate');
            if (gate) {
                gate.style.opacity = '0';
                setTimeout(() => {
                    gate.style.display = 'none';
                    document.body.classList.remove('overflow-hidden');
                }, 500);
                localStorage.setItem(`${STORE_CONFIG.id}_verified`, 'true');
            }
        }

        // Initialize Age Gate
        if(localStorage.getItem(`${STORE_CONFIG.id}_verified`) === 'true') {
            const gate = document.getElementById('age-gate');
            if (gate) gate.style.display = 'none';
        } else {
            document.body.classList.add('overflow-hidden');
        }

        // Event Listeners
        document.getElementById('verify-age-btn')?.addEventListener('click', verifyAge);

        document.getElementById('sms-form')?.addEventListener('submit', (event) => {
            event.preventDefault();
            const phoneInput = document.getElementById('phone-input') as HTMLInputElement | null;
            const hpField = document.getElementById('hp_full_name') as HTMLInputElement | null;
            const errorMsg = document.getElementById('error-message');
            const submitBtn = document.getElementById('submit-btn');
            const btnText = document.getElementById('btn-text');
            const btnSpinner = document.getElementById('btn-spinner');
            const success = document.getElementById('success-message');

            if (!hpField || hpField.value.length > 0) return;
            const phoneRegex = /^\(?([0-9]{3})\)?[-. ]?([0-9]{3})[-. ]?([0-9]{4})$/;
            
            if (!phoneInput || !phoneRegex.test(phoneInput.value)) {
                phoneInput?.classList.add('error-shake');
                errorMsg?.classList.remove('hidden');
                setTimeout(() => phoneInput?.classList.remove('error-shake'), 400);
                return;
            }

            errorMsg?.classList.add('hidden');
            btnText?.classList.add('hidden');
            btnSpinner?.classList.remove('hidden');
            if (submitBtn) {
                submitBtn.style.pointerEvents = 'none';
                submitBtn.style.opacity = '0.7';
            }

            setTimeout(() => {
                document.getElementById('sms-form')?.classList.add('hidden');
                success?.classList.remove('hidden');
            }, 1500);
        });
    </script>
</Layout>
