    <script>
        const STORE_CONFIG = {
            id: 'untouchable_v9_standard_map',
            phone: '4708736088'
        };

        function verifyAge() {
            const gate = document.getElementById('age-gate');
            if (gate) {
                gate.style.opacity = '0';
                setTimeout(() => {
                    gate.style.display = 'none';
                    document.body.classList.remove('overflow-hidden');
                }, 500);
                localStorage.setItem(`${STORE_CONFIG.id}_verified`, 'true');
            }
        }

        // Initialize Age Gate
        if(localStorage.getItem(`${STORE_CONFIG.id}_verified`) === 'true') {
            const gate = document.getElementById('age-gate');
            if (gate) gate.style.display = 'none';
        } else {
            document.body.classList.add('overflow-hidden');
        }

        // Event Listeners
        document.getElementById('verify-age-btn')?.addEventListener('click', verifyAge);

        // Lazy Load Map
        const loadMapBtn = document.getElementById('load-map-btn');
        const mapPlaceholder = document.getElementById('map-placeholder');
        const mapContainer = document.getElementById('map-container');

        function loadInteractiveMap() {
            if (!mapContainer || !mapPlaceholder) return;
            
            const iframe = document.createElement('iframe');
            iframe.src = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3316.8290263673757!2d-84.38883622415664!3d33.76949397326514!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x88f5047b744d21f3%3A0xe67d60505b380b2a!2sUntouchable%20Smoke%20Shop!5e0!3m2!1sen!2sus!4v1711660000000!5m2!1sen!2sus";
            iframe.width = "100%";
            iframe.height = "100%";
            iframe.style.border = "0";
            iframe.allowFullscreen = true;
            iframe.loading = "lazy";
            iframe.title = "Google Maps location of Untouchable Smoke Shop";
            iframe.className = "map-frame";
            
            mapContainer.appendChild(iframe);
            mapPlaceholder.style.opacity = '0';
            setTimeout(() => {
                mapPlaceholder.style.display = 'none';
                mapContainer.style.opacity = '1';
                mapContainer.classList.remove('pointer-events-none');
            }, 500);
        }

        loadMapBtn?.addEventListener('click', loadInteractiveMap);

        // Category Filtering
        const filterBtns = document.querySelectorAll('.category-pill');
        const products = document.querySelectorAll('.hot-card');

        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                filterBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                
                const filter = btn.getAttribute('data-filter');
                
                products.forEach(product => {
                    const el = product as HTMLElement;
                    if (filter === 'all' || el.getAttribute('data-category') === filter) {
                        el.style.display = 'block';
                        setTimeout(() => {
                            el.style.opacity = '1';
                            el.style.transform = 'translateY(0)';
                        }, 50);
                    } else {
                        el.style.opacity = '0';
                        el.style.transform = 'translateY(20px)';
                        setTimeout(() => {
                            el.style.display = 'none';
                        }, 300);
                    }
                });
            });
        });

        document.getElementById('sms-form')?.addEventListener('submit', (event) => {
            event.preventDefault();
            const phoneInput = document.getElementById('phone-input') as HTMLInputElement | null;
            const hpField = document.getElementById('hp_full_name') as HTMLInputElement | null;
            const errorMsg = document.getElementById('error-message');
            const submitBtn = document.getElementById('submit-btn');
            const btnText = document.getElementById('btn-text');
            const btnSpinner = document.getElementById('btn-spinner');
            const success = document.getElementById('success-message');

            if (!hpField || hpField.value.length > 0) return;
            const phoneRegex = /^\(?([0-9]{3})\)?[-. ]?([0-9]{3})[-. ]?([0-9]{4})$/;
            
            if (!phoneInput || !phoneRegex.test(phoneInput.value)) {
                phoneInput?.classList.add('error-shake');
                errorMsg?.classList.remove('hidden');
                setTimeout(() => phoneInput?.classList.remove('error-shake'), 400);
                return;
            }

            errorMsg?.classList.add('hidden');
            btnText?.classList.add('hidden');
            btnSpinner?.classList.remove('hidden');
            if (submitBtn) {
                submitBtn.style.pointerEvents = 'none';
                submitBtn.style.opacity = '0.7';
            }

            setTimeout(() => {
                document.getElementById('sms-form')?.classList.add('hidden');
                success?.classList.remove('hidden');
            }, 1500);
        });
    </script>
