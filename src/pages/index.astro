---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Untouchable Smoke Shop | Atlanta's #1 Midnight Spot (Midtown ATL)" description="Untouchable Smoke Shop in Midtown Atlanta offers the best prices on vapes, glass, and accessories near Georgia Tech. Located at 533 Peachtree St NE, open late until 2 AM.">
    <!-- FLOATING MOBILE CALL BUTTON -->
    <a href="tel:4708736088" class="fixed bottom-6 right-6 z-[60] md:hidden vibe-gradient w-16 h-16 rounded-full flex items-center justify-center shadow-2xl shadow-cyan-500/40 animate-bounce" aria-label="Call Shop Now">
        <i class="fa-solid fa-phone text-white text-2xl"></i>
    </a>

    <!-- AGE VERIFICATION OVERLAY -->
    <div id="age-gate" class="fixed inset-0 z-[100] bg-deep-black flex items-center justify-center p-4" role="dialog" aria-modal="true" aria-labelledby="age-gate-title">
        <div class="max-w-md 3xl:max-w-xl w-full glass-morphism p-8 3xl:p-12 rounded-3xl text-center border-teal-glow/30 border-2 shadow-2xl shadow-teal-glow/10">
            <div class="text-4xl 3xl:text-6xl mb-4 text-teal-glow animate-pulse"><i class="fa-solid fa-id-card" aria-hidden="true"></i></div>
            <h2 id="age-gate-title" class="text-3xl 3xl:text-5xl font-extrabold mb-4 uppercase tracking-tighter">Identity Check</h2>
            <p class="text-gray-300 mb-8 font-medium text-sm 3xl:text-base">You must be at least 21 years old to enter. Untouchable Smoke Shop strictly verifies IDs in-store.</p>
            <div class="flex flex-col gap-4">
                <button id="verify-age-btn" class="vibe-gradient py-4 3xl:py-6 px-8 rounded-xl font-bold text-white text-lg 3xl:text-2xl transition-transform hover:scale-105 active:scale-95 shadow-lg shadow-cyan-500/20" aria-label="Confirm I am 21 or older">
                    I AM 21+ YEARS OLD
                </button>
                <button onclick="window.location.href='https://google.com'" class="text-gray-400 hover:text-white transition-colors 3xl:text-lg uppercase tracking-widest font-bold text-sm" aria-label="Exit because I am under 21">
                    I am under 21
                </button>
            </div>
        </div>
    </div>

    <!-- GLOBAL TRUST BANNER -->
    <div class="vibe-gradient text-white text-[10px] md:text-xs 3xl:text-sm font-black py-2 3xl:py-3 px-4 text-center sticky top-0 z-50 uppercase tracking-widest shadow-lg" role="alert">
        🔞 STRICTLY 21+ ONLY. VALID ID REQUIRED. OPEN UNTIL 2AM FRI/SAT.
    </div>

    <!-- NAVIGATION -->
    <nav class="p-6 3xl:p-10 border-b border-white/5 flex justify-between items-center bg-black/50 backdrop-blur-md sticky top-[32px] md:top-[36px] 3xl:top-[44px] z-40" role="navigation" aria-label="Main Navigation">
        <div class="flex items-center gap-2 3xl:gap-4">
            <div class="w-10 h-10 3xl:w-14 3xl:h-14 vibe-gradient rounded-lg flex items-center justify-center shadow-lg shadow-teal-glow/20">
                <i class="fa-solid fa-crown text-white text-xl 3xl:text-3xl" aria-hidden="true"></i>
            </div>
            <span class="font-extrabold text-xl 3xl:text-3xl tracking-tighter uppercase">Untouchable <span class="text-bright-cyan">Smoke</span></span>
        </div>
        <div class="hidden md:flex gap-8 3xl:gap-16 text-gray-400">
            <a href="#hot-list" class="nav-link">Hot List</a>
            <a href="#calendar" class="nav-link">Calendar</a>
            <a href="#reviews" class="nav-link">Reviews</a>
            <a href="#location-map" class="nav-link text-bright-cyan border-b border-teal-glow">Location</a>
        </div>
        <a href="#optin" class="bg-white text-black py-2.5 px-6 3xl:px-10 rounded-full text-[10px] 3xl:text-sm font-black hover:bg-bright-cyan hover:text-white transition-all uppercase tracking-widest" aria-label="Get 10% discount">Get 10% Off</a>
    </nav>

    <!-- HERO SECTION -->
    <header class="relative py-24 md:py-32 3xl:py-56 px-6 max-w-[2000px] mx-auto text-center overflow-hidden">
        <div class="glow-blur -top-20 -left-20 w-80 h-80 3xl:w-[600px] 3xl:h-[600px] bg-olive-glow animate-float"></div>
        <div class="glow-blur top-40 -right-20 w-96 h-96 3xl:w-[800px] 3xl:h-[800px] bg-green-glow opacity-10"></div>
        
        <h1 class="hero-title">
            MIDNIGHT <br><span class="text-gradient">VIBES.</span>
        </h1>
        <p class="text-lg md:text-xl 3xl:text-3xl text-gray-300 max-w-2xl 3xl:max-w-5xl mx-auto mb-10 3xl:mb-20 font-medium leading-relaxed">
            Atlanta's premier late-night smoke shop. Exclusive drops, premium glass, and the best prices in Midtown. Open until 2 AM on weekends.
        </p>
        <div class="flex flex-wrap justify-center gap-4 3xl:gap-8">
            <a href="#hot-list" class="vibe-gradient px-10 py-5 3xl:px-16 3xl:py-8 rounded-full font-black text-white text-lg 3xl:text-2xl hover:shadow-cyan-500/30 shadow-xl transition-all hover:-translate-y-1">SHOP THE HOT LIST</a>
            <a href="#calendar" class="glass-morphism px-10 py-5 3xl:px-16 3xl:py-8 rounded-full font-black text-lg 3xl:text-2xl border border-white/10 uppercase tracking-wider hover:bg-white/5 transition-all">VIEW EVENTS</a>
        </div>
    </header>

    <!-- STATS -->
    <section class="max-w-[1800px] mx-auto px-6 grid grid-cols-2 lg:grid-cols-4 gap-4 3xl:gap-8 mb-20 3xl:mb-40 relative">
        <div class="glass-morphism p-6 3xl:p-12 rounded-2xl text-center border-t border-white/5 hover:border-teal-glow/30">
            <div class="text-3xl 3xl:text-6xl font-black text-bright-cyan mb-1">5.0</div>
            <div class="text-[10px] 3xl:text-sm text-gray-400 uppercase font-bold tracking-widest">Google Rating</div>
        </div>
        <div class="glass-morphism p-6 3xl:p-12 rounded-2xl text-center border-t border-white/5 hover:border-teal-glow/30">
            <div class="text-3xl 3xl:text-6xl font-black text-teal-glow mb-1">2AM</div>
            <div class="text-[10px] 3xl:text-sm text-gray-400 uppercase font-bold tracking-widest">Fri/Sat Close</div>
        </div>
        <div class="glass-morphism p-6 3xl:p-12 rounded-2xl text-center border-t border-white/5 hover:border-teal-glow/30">
            <div class="text-3xl 3xl:text-6xl font-black text-electric-blue mb-1">100%</div>
            <div class="text-[10px] 3xl:text-sm text-gray-400 uppercase font-bold tracking-widest">Authentic Gear</div>
        </div>
        <div class="glass-morphism p-6 3xl:p-12 rounded-2xl text-center border-t border-white/5 hover:border-teal-glow/30">
            <div class="text-3xl 3xl:text-6xl font-black text-white mb-1">ATL</div>
            <div class="text-[10px] 3xl:text-sm text-gray-400 uppercase font-bold tracking-widest">Best Selection</div>
        </div>
    </section>

    <!-- HOT LIST -->
    <section id="hot-list" class="py-20 3xl:py-40 px-6 max-w-[1800px] mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 3xl:mb-24 gap-6">
            <div>
                <h2 class="text-4xl 3xl:text-7xl font-black tracking-tighter mb-2 uppercase italic">The <span class="text-purple-vibe">Hot List</span></h2>
                <p class="text-gray-300 3xl:text-2xl">What's trending at 533 Peachtree right now.</p>
            </div>
            <div class="flex gap-2 overflow-x-auto pb-2 w-full md:w-auto" id="category-filters">
                <button class="category-pill active" data-filter="all">All</button>
                <button class="category-pill" data-filter="vapes">Vapes</button>
                <button class="category-pill" data-filter="glass">Glass</button>
            </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 3xl:gap-12" id="product-grid">
            <!-- Product 1 -->
            <article class="hot-card group" data-category="vapes">
                <div class="absolute top-6 right-6 bg-teal-glow text-white text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest animate-pulse">In Stock</div>
                <div class="text-teal-glow text-3xl 3xl:text-5xl mb-6"><i class="fa-solid fa-bolt"></i></div>
                <h3 class="text-2xl 3xl:text-4xl font-black mb-2 uppercase">Geek Bar Pulse</h3>
                <p class="text-gray-400 text-sm 3xl:text-xl mb-6">The most requested disposable in ATL. Dual mesh coil, full screen display.</p>
                <div class="flex justify-between items-center mt-auto">
                    <span class="text-xl font-black text-white">$24.99</span>
                    <button class="text-xs font-bold uppercase tracking-widest text-teal-glow hover:text-white transition-colors">Get Offer <i class="fa-solid fa-arrow-right ml-1"></i></button>
                </div>
            </article>

            <!-- Product 2 -->
            <article class="hot-card group" data-category="glass">
                <div class="absolute top-6 right-6 bg-purple-vibe text-white text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest">New</div>
                <div class="text-purple-vibe text-3xl 3xl:text-5xl mb-6"><i class="fa-solid fa-fire"></i></div>
                <h3 class="text-2xl 3xl:text-4xl font-black mb-2 uppercase">Artisan Beakers</h3>
                <p class="text-gray-400 text-sm 3xl:text-xl mb-6">Hand-blown, thick glass. Perfect for your daily driver.</p>
                <div class="flex justify-between items-center mt-auto">
                    <span class="text-xl font-black text-white">From $45</span>
                    <button class="text-xs font-bold uppercase tracking-widest text-purple-vibe hover:text-white transition-colors">Get Offer <i class="fa-solid fa-arrow-right ml-1"></i></button>
                </div>
            </article>

            <!-- Product 3 -->
            <article class="hot-card group" data-category="vapes">
                <div class="absolute top-6 right-6 bg-red-500 text-white text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest animate-pulse">Low Stock</div>
                <div class="text-red-500 text-3xl 3xl:text-5xl mb-6"><i class="fa-solid fa-wind"></i></div>
                <h3 class="text-2xl 3xl:text-4xl font-black mb-2 uppercase">Lost Mary MT15000</h3>
                <p class="text-gray-400 text-sm 3xl:text-xl mb-6">Turbo mode enabled. Selling out fast this weekend.</p>
                <div class="flex justify-between items-center mt-auto">
                    <span class="text-xl font-black text-white">$22.99</span>
                    <button class="text-xs font-bold uppercase tracking-widest text-red-500 hover:text-white transition-colors">Remind Me <i class="fa-solid fa-bell ml-1"></i></button>
                </div>
            </article>
        </div>
    </section>

    <!-- PEACHTREE PULSE CALENDAR -->
    <section id="calendar" class="py-20 3xl:py-40 px-6 max-w-[1800px] mx-auto">
        <div class="bg-charcoal/50 rounded-[40px] border border-white/5 overflow-hidden">
            <div class="p-8 md:p-12 3xl:p-20 border-b border-white/5 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
                <div>
                    <h2 class="text-4xl 3xl:text-7xl font-black tracking-tighter mb-2 uppercase italic">Peachtree <span class="text-electric-blue">Pulse</span></h2>
                    <p class="text-gray-300 3xl:text-2xl">Upcoming events and drops.</p>
                </div>
                <a href="sms:+14708736088?body=I'm%20interested%20in%20collaborating%20on%20an%20event!" class="glass-morphism px-6 py-3 rounded-full text-sm font-bold uppercase tracking-widest hover:bg-white/10 transition-colors flex items-center gap-2">
                    <i class="fa-solid fa-comment-sms text-electric-blue"></i> DM us to collaborate
                </a>
            </div>
            
            <div class="flex flex-col">
                <!-- Event 1 -->
                <div class="event-row group">
                    <div class="flex items-center gap-6 mb-4 md:mb-0">
                        <div class="w-16 h-16 rounded-2xl bg-purple-vibe/20 text-purple-vibe flex flex-col items-center justify-center border border-purple-vibe/30 shrink-0">
                            <span class="text-xs font-bold uppercase">Oct</span>
                            <span class="text-xl font-black leading-none">24</span>
                        </div>
                        <div>
                            <div class="text-[10px] font-black text-purple-vibe uppercase tracking-widest mb-1">Art Show</div>
                            <h3 class="text-xl md:text-2xl font-black uppercase">Local Glass Blowers Showcase</h3>
                        </div>
                    </div>
                    <div class="flex items-center gap-6 w-full md:w-auto justify-between md:justify-end">
                        <div class="text-sm text-gray-400 font-bold"><i class="fa-regular fa-clock mr-2"></i>8PM - 12AM</div>
                        <button class="text-electric-blue hover:text-white transition-colors"><i class="fa-solid fa-arrow-right text-xl"></i></button>
                    </div>
                </div>

                <!-- Event 2 -->
                <div class="event-row group">
                    <div class="flex items-center gap-6 mb-4 md:mb-0">
                        <div class="w-16 h-16 rounded-2xl bg-teal-glow/20 text-teal-glow flex flex-col items-center justify-center border border-teal-glow/30 shrink-0">
                            <span class="text-xs font-bold uppercase">Oct</span>
                            <span class="text-xl font-black leading-none">31</span>
                        </div>
                        <div>
                            <div class="text-[10px] font-black text-teal-glow uppercase tracking-widest mb-1">Stock Drop</div>
                            <h3 class="text-xl md:text-2xl font-black uppercase">Halloween Exclusive Vapes</h3>
                        </div>
                    </div>
                    <div class="flex items-center gap-6 w-full md:w-auto justify-between md:justify-end">
                        <div class="text-sm text-gray-400 font-bold"><i class="fa-regular fa-clock mr-2"></i>All Day</div>
                        <button class="text-electric-blue hover:text-white transition-colors"><i class="fa-solid fa-arrow-right text-xl"></i></button>
                    </div>
                </div>

                <!-- Event 3 -->
                <div class="event-row group">
                    <div class="flex items-center gap-6 mb-4 md:mb-0">
                        <div class="w-16 h-16 rounded-2xl bg-bright-cyan/20 text-bright-cyan flex flex-col items-center justify-center border border-bright-cyan/30 shrink-0">
                            <span class="text-xs font-bold uppercase">Nov</span>
                            <span class="text-xl font-black leading-none">05</span>
                        </div>
                        <div>
                            <div class="text-[10px] font-black text-bright-cyan uppercase tracking-widest mb-1">Concert Night</div>
                            <h3 class="text-xl md:text-2xl font-black uppercase">Pre-Game Pop Up</h3>
                        </div>
                    </div>
                    <div class="flex items-center gap-6 w-full md:w-auto justify-between md:justify-end">
                        <div class="text-sm text-gray-400 font-bold"><i class="fa-regular fa-clock mr-2"></i>6PM - 9PM</div>
                        <button class="text-electric-blue hover:text-white transition-colors"><i class="fa-solid fa-arrow-right text-xl"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- MAP SECTION -->
    <section id="location-map" class="py-20 3xl:py-40 px-6 max-w-[1800px] mx-auto overflow-hidden">
        <div class="grid lg:grid-cols-2 gap-12 3xl:gap-24 items-center">
            <div class="space-y-8">
                <h2 class="text-4xl 3xl:text-7xl font-black tracking-tighter uppercase italic">
                    Pull Up to <span class="text-bright-cyan">Peachtree</span>
                </h2>
                <p class="text-gray-300 3xl:text-2xl font-medium leading-relaxed max-w-xl">
                    Located in the heart of Atlanta. Look for the neon glow at 533 Peachtree St NE. We're the midnight destination for the city's premium smoke needs.
                </p>
                <div class="flex flex-col gap-4">
                    <a href="https://maps.app.goo.gl/DBnPu5MiW5beXzQg4" target="_blank" class="vibe-gradient px-8 py-5 rounded-2xl font-black text-white text-center hover:scale-105 transition-all shadow-lg flex items-center justify-center gap-3 text-lg 3xl:text-2xl">
                        <i class="fa-solid fa-diamond-turn-right"></i> GET DIRECTIONS
                    </a>
                    <div class="flex gap-4 items-center text-gray-400 font-bold uppercase tracking-widest text-xs 3xl:text-lg">
                        <i class="fa-solid fa-clock text-teal-glow"></i> Open until Midnight (2AM Weekends)
                    </div>
                </div>
            </div>

            <div class="relative aspect-video lg:aspect-square rounded-[40px] overflow-hidden border border-white/10 shadow-2xl shadow-teal-glow/5 group">
                <!-- Static Map Placeholder -->
                <div id="map-placeholder" class="absolute inset-0 bg-charcoal flex flex-col items-center justify-center text-center p-6 transition-opacity duration-500">
                    <div class="absolute inset-0 opacity-40 grayscale group-hover:opacity-60 transition-opacity">
                        <img 
                            src="https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?auto=format&fit=crop&w=800&q=60" 
                            alt="Map Background" 
                            class="w-full h-full object-cover"
                            referrerpolicy="no-referrer"
                        />
                    </div>
                    <div class="relative z-10">
                        <div class="w-20 h-20 vibe-gradient rounded-full flex items-center justify-center mb-6 mx-auto shadow-xl shadow-cyan-500/40 group-hover:scale-110 transition-transform cursor-pointer" id="load-map-btn">
                            <i class="fa-solid fa-location-dot text-white text-3xl"></i>
                        </div>
                        <h3 class="text-xl font-black uppercase mb-2">Interactive Map</h3>
                        <p class="text-gray-400 text-sm font-bold uppercase tracking-widest">Click to load live directions</p>
                    </div>
                </div>
                <!-- Interactive Iframe (Hidden by default) -->
                <div id="map-container" class="absolute inset-0 opacity-0 pointer-events-none transition-opacity duration-700 h-full w-full">
                    <!-- Iframe will be injected here -->
                </div>
            </div>
        </div>
    </section>

    <!-- REVIEWS -->
    <section id="reviews" class="bg-charcoal/30 py-24 3xl:py-48 px-6 relative">
        <div class="glow-blur absolute inset-0 bg-olive-glow opacity-5 animate-pulse-slow"></div>
        <div class="max-w-[1800px] mx-auto relative z-10">
            <h2 class="text-4xl 3xl:text-7xl font-black tracking-tighter mb-12 3xl:mb-24 uppercase text-center italic">Trusted by the <span class="text-bright-cyan">City</span></h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 3xl:gap-12">
                <figure class="glass-morphism p-6 3xl:p-12 rounded-2xl hover:-translate-y-2">
                    <div class="flex text-teal-glow mb-4 text-xs 3xl:text-lg"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                    <blockquote class="text-sm 3xl:text-xl italic mb-4 text-gray-300">"Hikeen is so sweet and very attentive! They’re so friendly and have amazing prices!"</blockquote>
                    <figcaption class="text-xs 3xl:text-sm font-bold uppercase tracking-widest text-bright-cyan">— Jaden Droge</figcaption>
                </figure>
                <figure class="glass-morphism p-6 3xl:p-12 rounded-2xl border-bright-cyan/20 hover:-translate-y-2">
                    <div class="flex text-bright-cyan mb-4 text-xs 3xl:text-lg"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                    <blockquote class="text-sm 3xl:text-xl italic mb-4 text-gray-300">"BEST PRICES IN ATLANTA THANKS FOR THE BEST PRICES. Very clean and amazing atmosphere!!"</blockquote>
                    <figcaption class="text-xs 3xl:text-sm font-bold uppercase tracking-widest text-bright-cyan">— Tyreak Muhammad</figcaption>
                </figure>
                <figure class="glass-morphism p-6 3xl:p-12 rounded-2xl hover:-translate-y-2">
                    <div class="flex text-teal-glow mb-4 text-xs 3xl:text-lg"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                    <blockquote class="text-sm 3xl:text-xl italic mb-4 text-gray-300">"Customer Service was very embracing I will continue to Shop due to reasonable prices."</blockquote>
                    <figcaption class="text-xs 3xl:text-sm font-bold uppercase tracking-widest text-bright-cyan">— Thomas Scott</figcaption>
                </figure>
            </div>
        </div>
    </section>

    <!-- SMS OPT-IN -->
    <section id="optin" class="py-32 3xl:py-64 px-6">
        <div class="max-w-4xl 3xl:max-w-7xl mx-auto vibe-gradient p-[1px] rounded-[40px] shadow-2xl shadow-cyan-500/20">
            <div class="bg-deep-black rounded-[39px] p-8 md:p-16 3xl:p-32 text-center relative overflow-hidden">
                <div class="glow-blur -bottom-20 -left-20 w-64 h-64 3xl:w-[600px] 3xl:h-[600px] bg-bright-cyan !opacity-10"></div>
                <h2 class="text-4xl md:text-6xl 3xl:text-8xl font-black tracking-tighter mb-6 uppercase">Get the <span class="text-bright-cyan">VIP</span> Connection.</h2>
                <p class="text-lg 3xl:text-3xl text-gray-300 mb-10 3xl:mb-20 font-medium">Be the first to know about new glass drops and flash sales. Plus, 10% off your next visit.</p>
                <form id="sms-form" class="max-w-md 3xl:max-w-2xl mx-auto space-y-4 relative z-10">
                    <div class="visually-hidden-hp" aria-hidden="true">
                        <label for="hp_full_name">Full Name</label>
                        <input type="text" id="hp_full_name" name="hp_full_name" tabindex="-1" autocomplete="off">
                    </div>
                    <div class="flex flex-col md:flex-row gap-4 relative">
                        <input type="tel" id="phone-input" placeholder="Mobile Number" required class="flex-1 bg-white/5 border border-white/10 rounded-2xl px-6 py-4 3xl:py-8 3xl:px-10 text-white 3xl:text-2xl focus:outline-none focus:border-teal-glow transition-all placeholder:text-gray-600 font-bold tracking-widest">
                        <button type="submit" id="submit-btn" class="vibe-gradient px-8 py-4 3xl:px-12 3xl:py-8 rounded-2xl font-black text-white 3xl:text-2xl whitespace-nowrap hover:scale-105 active:scale-95 transition-all shadow-lg flex items-center justify-center min-w-[140px]">
                            <span id="btn-text">SIGN ME UP</span>
                            <i id="btn-spinner" class="fa-solid fa-circle-notch fa-spin hidden"></i>
                        </button>
                    </div>
                    <p id="error-message" class="text-[10px] 3xl:text-sm text-red-500 font-bold uppercase tracking-widest hidden text-center">Please enter a valid 10-digit phone number.</p>
                    <p class="text-[10px] 3xl:text-sm text-gray-400 text-center uppercase tracking-widest font-bold">21+ Only. Msg/Data rates apply.</p>
                </form>
                <div id="success-message" class="hidden mt-8 text-teal-glow font-black text-xl 3xl:text-4xl animate-bounce italic tracking-widest">WELCOME. CHECK YOUR TEXTS.</div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="border-t border-white/5 pt-20 3xl:pt-40 pb-10 px-6 bg-deep-black relative">
        <div class="glow-blur bottom-0 right-0 w-64 h-64 3xl:w-[600px] 3xl:h-[600px] bg-green-glow !opacity-10"></div>
        <div class="max-w-[1800px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 3xl:gap-24 mb-20 relative z-10">
            <div>
                <div class="flex items-center gap-2 mb-6">
                    <div class="w-8 h-8 3xl:w-12 3xl:h-12 vibe-gradient rounded-md flex items-center justify-center">
                        <i class="fa-solid fa-crown text-white text-sm 3xl:text-xl"></i>
                    </div>
                    <span class="font-extrabold text-xl 3xl:text-3xl tracking-tighter uppercase">UNTOUCHABLE</span>
