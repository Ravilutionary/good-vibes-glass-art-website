---
import Layout from '../layouts/Layout.astro';
import AgeGate from '../components/global/AgeGate.astro';
import Navbar from '../components/global/Navbar.astro';
import MobileStickyBar from '../components/global/MobileStickyBar.astro';
import Footer from '../components/global/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import EventCountdown from '../components/sections/EventCountdown.astro';
import BrandSlider from '../components/sections/BrandSlider.astro';
import Stats from '../components/sections/Stats.astro';
import HotList from '../components/sections/HotList.astro';
import Calendar from '../components/sections/Calendar.astro';
import LocationMap from '../components/sections/LocationMap.astro';
import LocalLandmarks from '../components/sections/LocalLandmarks.astro';
import Reviews from '../components/sections/Reviews.astro';
import RecentPosts from '../components/sections/RecentPosts.astro';
import VIPForm from '../components/sections/VIPForm.astro';
---

<Layout title="Untouchable Smoke Shop | Atlanta's Premier Smoke & Vape Destination" description="Untouchable Smoke Shop in Midtown Atlanta offers the best prices on authentic vapes, premium glass, and cigars near Georgia Tech. Free retail parking, open late.">
    <MobileStickyBar />

    <AgeGate />
    <Navbar />

    <div class="min-h-[calc(100svh-120px)] md:min-h-[calc(100svh-140px)] flex flex-col justify-between overflow-hidden">
        <div class="flex-1 flex flex-col justify-center">
            <Hero />
        </div>
        <div>
            <BrandSlider />
        </div>
    </div>
    
    <EventCountdown />
    <Stats />
    <HotList />
    <Calendar />
    <LocationMap />
    <LocalLandmarks />
    <Reviews />
    <RecentPosts />
    <VIPForm />

    <Footer />

</Layout>
