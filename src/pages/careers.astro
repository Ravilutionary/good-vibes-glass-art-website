---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Careers | Untouchable Smoke Shop" description="Join the crew at Untouchable Smoke Shop. Think you can handle the floor?">
    <main class="pt-32 pb-24 px-6 max-w-4xl mx-auto min-h-[80vh] flex flex-col justify-center">
        <div class="text-center mb-16">
            <div class="inline-block bg-white/10 border border-white/20 rounded-full px-4 py-1.5 mb-6 backdrop-blur-md">
                <p class="text-purple-vibe font-bold uppercase tracking-widest text-xs">Join The Crew</p>
            </div>
            <h1 class="text-4xl md:text-6xl font-black uppercase tracking-tighter text-white mb-6 leading-tight">
                Think you can <br><span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-vibe to-bright-cyan">handle the floor?</span>
            </h1>
            <p class="text-gray-300 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
                We're always looking for knowledgeable, high-energy people to join the team. If you know the industry and can provide top-tier service, send your stats.
            </p>
        </div>

        <div class="bg-black/40 p-8 md:p-12 rounded-[2rem] border border-white/10 backdrop-blur-xl shadow-2xl relative overflow-hidden">
            <div class="glow-blur -top-20 -right-20 w-64 h-64 bg-purple-vibe/20 pointer-events-none"></div>
            
            <form id="careers-form" class="relative z-10 space-y-6" onsubmit="event.preventDefault(); /* TODO: Add fetch to Formspree here */ document.getElementById('careers-form').classList.add('hidden'); document.getElementById('careers-success').classList.remove('hidden');">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label for="name" class="text-sm font-bold uppercase tracking-widest text-gray-400">Full Name</label>
                        <input type="text" id="name" name="name" required class="w-full bg-white/5 border border-white/10 rounded-xl px-6 py-4 text-white focus:outline-none focus:border-purple-vibe transition-all font-medium">
                    </div>
                    <div class="space-y-2">
                        <label for="phone" class="text-sm font-bold uppercase tracking-widest text-gray-400">Phone Number</label>
                        <input type="tel" id="phone" name="phone" required class="w-full bg-white/5 border border-white/10 rounded-xl px-6 py-4 text-white focus:outline-none focus:border-purple-vibe transition-all font-medium">
                    </div>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label for="email" class="text-sm font-bold uppercase tracking-widest text-gray-400">Email Address</label>
                        <input type="email" id="email" name="email" required class="w-full bg-white/5 border border-white/10 rounded-xl px-6 py-4 text-white focus:outline-none focus:border-purple-vibe transition-all font-medium">
                    </div>
                    <div class="space-y-2">
                        <label for="experience" class="text-sm font-bold uppercase tracking-widest text-gray-400">Years of Experience</label>
                        <select id="experience" name="experience" required class="w-full bg-deep-black border border-white/10 rounded-xl px-6 py-4 text-white focus:outline-none focus:border-purple-vibe transition-all font-medium appearance-none">
                            <option value="" disabled selected>Select Experience Level</option>
                            <option value="0-1">0-1 Years</option>
                            <option value="1-3">1-3 Years</option>
                            <option value="3-5">3-5 Years</option>
                            <option value="5+">5+ Years</option>
                        </select>
                    </div>
                </div>

                <div class="space-y-2">
                    <label for="knowledge" class="text-sm font-bold uppercase tracking-widest text-gray-400">Your Expertise (Vapes, Glass, Cigars, etc.)</label>
                    <textarea id="knowledge" name="knowledge" rows="4" required class="w-full bg-white/5 border border-white/10 rounded-xl px-6 py-4 text-white focus:outline-none focus:border-purple-vibe transition-all font-medium resize-none"></textarea>
                </div>

                <button type="submit" class="w-full bg-gradient-to-r from-purple-vibe to-bright-cyan px-8 py-5 rounded-xl font-black text-white uppercase tracking-widest hover:scale-[1.02] active:scale-[0.98] transition-all text-lg shadow-[0_0_20px_rgba(138,43,226,0.3)] mt-4">
                    Show Your Knowledge
                </button>
            </form>

            <div id="careers-success" class="hidden text-center py-12 relative z-10">
                <i class="fa-solid fa-check-circle text-6xl text-purple-vibe mb-6"></i>
                <h3 class="text-3xl font-black uppercase tracking-tighter text-white mb-4">Stats Sent</h3>
                <p class="text-gray-300 text-lg">Application received. Stay tuned.</p>
            </div>
        </div>
    </main>
</Layout>
