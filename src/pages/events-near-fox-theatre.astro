---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/global/Navbar.astro';
import Footer from '../components/global/Footer.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import EventCard from '../components/ui/EventCard.astro';

const allEvents = await getCollection('events');
// Filter for Fox Theatre events
const events = allEvents.filter(event => event.data.venue.includes('Fox Theatre')).sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
---

<Layout 
  title="Events Near Fox Theatre in Atlanta | Untouchable Smoke Shop"
  description="Attending a show at the Fox Theatre? Untouchable Smoke Shop is just a short walk away on Peachtree Street. Check out upcoming events and visit us today."
>
  <Navbar />
  
  <main class="pt-32 pb-20 px-6 max-w-[1800px] mx-auto">
    <div class="text-center max-w-4xl mx-auto mb-16">
      <SectionHeader 
        title="Events Near" 
        accentText="Fox Theatre" 
        accentColor="text-purple-vibe" 
        subtitle="Catching a show at the historic Fox Theatre? We're located just blocks away. Stop by Untouchable Smoke Shop before or after the show for premium vapes, glass, and cigars."
        alignment="center"
      />
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {events.map(event => (
        <EventCard 
          title={event.data.title}
          date={event.data.date}
          endDate={event.data.endDate}
          venue={event.data.venue}
          category={event.data.category}
          time={event.data.time}
          slug={event.slug}
        />
      ))}
    </div>
    
    {events.length === 0 && (
      <div class="text-center text-gray-400 py-12">
        <p class="text-xl font-bold">No upcoming events listed for Fox Theatre right now, but check back soon!</p>
      </div>
    )}
  </main>
  
  <Footer />
</Layout>
