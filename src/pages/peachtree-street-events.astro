---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/global/Navbar.astro';
import Footer from '../components/global/Footer.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import EventCard from '../components/ui/EventCard.astro';

const allEvents = await getCollection('events');
const events = allEvents.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
---

<Layout 
  title="Peachtree Street Atlanta Event Calendar | Untouchable Smoke Shop"
  description="Explore events happening on and around Peachtree Street in Atlanta. Untouchable Smoke Shop is your premier destination at 533 Peachtree St NE."
>
  <Navbar />
  
  <main class="pt-32 pb-20 px-6 max-w-[1800px] mx-auto">
    <div class="text-center max-w-4xl mx-auto mb-16">
      <SectionHeader 
        title="Peachtree Street" 
        accentText="Events" 
        accentColor="text-teal-glow" 
        subtitle="Peachtree Street is the heartbeat of Atlanta. Discover what's happening nearby and make Untouchable Smoke Shop your first stop."
        alignment="center"
      />
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {events.map(event => (
        <EventCard 
          title={event.data.title}
          date={event.data.date}
          endDate={event.data.endDate}
          venue={event.data.venue}
          category={event.data.category}
          time={event.data.time}
          slug={event.slug}
        />
      ))}
    </div>
  </main>
  
  <Footer />
</Layout>
