---
import Layout from '../layouts/Layout.astro';
import AgeGate from '../components/global/AgeGate.astro';
import Navbar from '../components/global/Navbar.astro';
import MobileStickyBar from '../components/global/MobileStickyBar.astro';
import Footer from '../components/global/Footer.astro';
import CategoryHero from '../components/ui/CategoryHero.astro';
import LocalLandmarks from '../components/sections/LocalLandmarks.astro';
---

<Layout title="Premium Glass Pipes & Water Pipes in Atlanta | Untouchable Smoke Shop" description="Discover the finest selection of hand-blown glass, water pipes, bubblers, and dab rigs in Midtown Atlanta. Top brands like Illadelph, ROOR, and local artists.">
    <MobileStickyBar />
    <AgeGate />
    <Navbar />

    <CategoryHero 
        title="Premium Glass" 
        subtitle="Functional Art & High-End Pieces"
        description="From daily drivers to heady, one-of-a-kind functional art pieces. We curate the best glass from renowned brands and local Atlanta artists."
        accentColor="text-teal-glow"
    />

    <section class="py-20 3xl:py-40 4xl:py-56 px-6 max-w-[1800px] 4xl:max-w-[2400px] mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 3xl:gap-16 4xl:gap-24">
            <!-- Product Category 1 -->
            <div class="glass-morphism p-8 3xl:p-14 4xl:p-20 rounded-3xl border-t border-white/5 hover:border-teal-glow/50 transition-all group">
                <div class="w-16 h-16 3xl:w-24 3xl:h-24 4xl:w-32 4xl:h-32 rounded-2xl bg-teal-glow/10 flex items-center justify-center mb-6 4xl:mb-10 group-hover:scale-110 transition-transform">
                    <i class="fa-solid fa-flask text-3xl 3xl:text-5xl 4xl:text-7xl text-teal-glow"></i>
                </div>
                <h3 class="text-2xl 3xl:text-4xl 4xl:text-6xl font-black uppercase tracking-widest mb-4 4xl:mb-8">Water Pipes & Bongs</h3>
                <p class="text-gray-400 text-sm 3xl:text-xl 4xl:text-3xl leading-relaxed mb-6 4xl:mb-10">Thick, durable borosilicate glass. Beakers, straight tubes, percolators, and scientific glass designed for the smoothest hits.</p>
                <ul class="space-y-2 4xl:space-y-4 text-gray-300 font-medium text-sm 3xl:text-xl 4xl:text-3xl">
                    <li><i class="fa-solid fa-check text-teal-glow mr-2"></i> ROOR</li>
                    <li><i class="fa-solid fa-check text-teal-glow mr-2"></i> Illadelph</li>
                    <li><i class="fa-solid fa-check text-teal-glow mr-2"></i> Grav Labs</li>
                </ul>
            </div>

            <!-- Product Category 2 -->
            <div class="glass-morphism p-8 3xl:p-14 4xl:p-20 rounded-3xl border-t border-white/5 hover:border-electric-blue/50 transition-all group">
                <div class="w-16 h-16 3xl:w-24 3xl:h-24 4xl:w-32 4xl:h-32 rounded-2xl bg-electric-blue/10 flex items-center justify-center mb-6 4xl:mb-10 group-hover:scale-110 transition-transform">
                    <i class="fa-solid fa-fire-flame-curved text-3xl 3xl:text-5xl 4xl:text-7xl text-electric-blue"></i>
                </div>
                <h3 class="text-2xl 3xl:text-4xl 4xl:text-6xl font-black uppercase tracking-widest mb-4 4xl:mb-8">Dab Rigs & E-Rigs</h3>
                <p class="text-gray-400 text-sm 3xl:text-xl 4xl:text-3xl leading-relaxed mb-6 4xl:mb-10">Elevate your concentrates with our selection of specialized rigs, quartz bangers, carb caps, and the latest electronic smart rigs.</p>
                <ul class="space-y-2 4xl:space-y-4 text-gray-300 font-medium text-sm 3xl:text-xl 4xl:text-3xl">
                    <li><i class="fa-solid fa-check text-electric-blue mr-2"></i> Puffco Peak Pro</li>
                    <li><i class="fa-solid fa-check text-electric-blue mr-2"></i> Carta 2</li>
                    <li><i class="fa-solid fa-check text-electric-blue mr-2"></i> Custom Heady Rigs</li>
                </ul>
            </div>

            <!-- Product Category 3 -->
            <div class="glass-morphism p-8 3xl:p-14 4xl:p-20 rounded-3xl border-t border-white/5 hover:border-purple-vibe/50 transition-all group">
                <div class="w-16 h-16 3xl:w-24 3xl:h-24 4xl:w-32 4xl:h-32 rounded-2xl bg-purple-vibe/10 flex items-center justify-center mb-6 4xl:mb-10 group-hover:scale-110 transition-transform">
                    <i class="fa-solid fa-spoon text-3xl 3xl:text-5xl 4xl:text-7xl text-purple-vibe"></i>
                </div>
                <h3 class="text-2xl 3xl:text-4xl 4xl:text-6xl font-black uppercase tracking-widest mb-4 4xl:mb-8">Hand Pipes & Chillums</h3>
                <p class="text-gray-400 text-sm 3xl:text-xl 4xl:text-3xl leading-relaxed mb-6 4xl:mb-10">Perfect for on-the-go. Spoons, sherlocks, bubblers, and one-hitters in every color and style imaginable.</p>
                <ul class="space-y-2 4xl:space-y-4 text-gray-300 font-medium text-sm 3xl:text-xl 4xl:text-3xl">
                    <li><i class="fa-solid fa-check text-purple-vibe mr-2"></i> Color Changing Glass</li>
                    <li><i class="fa-solid fa-check text-purple-vibe mr-2"></i> Silicone Pipes</li>
                    <li><i class="fa-solid fa-check text-purple-vibe mr-2"></i> Local Blown Spoons</li>
                </ul>
            </div>
        </div>
    </section>

    <LocalLandmarks />
    <Footer />
</Layout>
