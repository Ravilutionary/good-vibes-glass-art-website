---
import aiPrompt from '../../data/ai-prompt.md?raw';

const encodedPrompt = encodeURIComponent(aiPrompt.trim());

const aiLinks = [
    {
        name: "Gemini",
        url: `https://gemini.google.com/app`,
        icon: "fa-solid fa-wand-magic-sparkles",
        color: "bg-gradient-to-r from-blue-500 to-purple-500 text-white border-transparent",
        id: "gemini-ai-link"
    },
    {
        name: "ChatGPT",
        url: `https://chatgpt.com/?q=${encodedPrompt}`,
        icon: "fa-solid fa-robot",
        color: "bg-[#10a37f] text-white border-transparent"
    },
    {
        name: "Claude",
        url: `https://claude.ai/new?q=${encodedPrompt}`,
        icon: "fa-solid fa-microchip",
        color: "bg-[#d97757] text-white border-transparent"
    },
    {
        name: "Grok",
        url: `https://x.com/i/grok?text=${encodedPrompt}`,
        icon: "fa-brands fa-x-twitter",
        color: "bg-black text-white border-white/20"
    },
    {
        name: "Perplexity",
        url: `https://www.perplexity.ai/search?q=${encodedPrompt}`,
        icon: "fa-solid fa-magnifying-glass",
        color: "bg-[#22b8cd] text-white border-transparent"
    }
];
---
<!-- FOOTER -->
<footer class="border-t border-white/5 pt-20 3xl:pt-40 4xl:pt-60 pb-10 px-6 bg-deep-black relative">
    <div class="glow-blur bottom-0 right-0 w-64 h-64 3xl:w-[600px] 3xl:h-[600px] 4xl:w-[800px] 4xl:h-[800px] bg-green-glow !opacity-10"></div>
    
    <!-- MAIN FOOTER GRID -->
    <div class="max-w-[1800px] 4xl:max-w-[2400px] mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 3xl:gap-24 4xl:gap-32 mb-16 4xl:mb-24 relative z-10">
        <!-- Brand -->
        <div>
            <div class="flex items-center gap-2 mb-6 4xl:mb-10">
                <div class="w-8 h-8 3xl:w-12 3xl:h-12 4xl:w-16 4xl:h-16 vibe-gradient rounded-md flex items-center justify-center">
                    <i class="fa-solid fa-crown text-white text-sm 3xl:text-xl 4xl:text-3xl"></i>
                </div>
                <span class="font-extrabold text-xl 3xl:text-3xl 4xl:text-5xl tracking-tighter uppercase">UNTOUCHABLE</span>
            </div>
            <p class="text-gray-400 mb-6 4xl:mb-10 font-medium text-sm 3xl:text-xl 4xl:text-3xl leading-relaxed">Downtown Atlanta's top-rated destination for smoking accessories, vapes, and high-end glass. Certified retailer.</p>
            <div class="flex gap-6 4xl:gap-10 text-xl 3xl:text-3xl 4xl:text-5xl text-gray-400 mb-8">
                <a href="https://www.instagram.com/untouchablesmoke533/" class="hover:text-bright-cyan transition-colors" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                <a href="https://www.yelp.com/biz/untouchable-smoke-shop-atlanta" class="hover:text-bright-cyan transition-colors" aria-label="Yelp"><i class="fa-brands fa-yelp"></i></a>
                <a href="https://share.google/DBnPu5MiW5beXzQg4" class="hover:text-bright-cyan transition-colors" aria-label="Google"><i class="fa-brands fa-google"></i></a>
            </div>
            <div class="flex gap-4 text-sm font-bold uppercase tracking-widest text-gray-400">
                <a href="/vendors" class="hover:text-bright-cyan transition-colors">Pitch the Shop</a>
                <span class="opacity-50">|</span>
                <a href="/careers" class="hover:text-bright-cyan transition-colors">Join the Crew</a>
            </div>
        </div>

        <!-- Hours -->
        <div>
            <h3 class="font-black mb-6 4xl:mb-10 text-white uppercase tracking-widest text-xs 3xl:text-base 4xl:text-2xl">Hours of Operation</h3>
            <ul class="space-y-3 4xl:space-y-6 text-sm 3xl:text-xl 4xl:text-3xl text-gray-300 font-bold uppercase tracking-tight">
                <li class="flex justify-between"><span>Mon - Thu</span> <span class="text-gray-400">10AM - 12AM</span></li>
                <li class="flex justify-between text-bright-cyan"><span>Fri - Sat</span> <span class="font-black">10AM - 2AM</span></li>
                <li class="flex justify-between"><span>Sunday</span> <span class="text-gray-400">10AM - 12AM</span></li>
            </ul>
        </div>

        <!-- Landmarks -->
        <div>
            <h3 class="font-black mb-6 4xl:mb-10 text-white uppercase tracking-widest text-xs 3xl:text-base 4xl:text-2xl">Your Go-To Shop Near</h3>
            <ul class="space-y-3 4xl:space-y-6 text-sm 3xl:text-xl 4xl:text-3xl text-gray-300 font-bold uppercase tracking-tight">
                <li><i class="fa-solid fa-masks-theater w-6 text-purple-vibe"></i> The Fox Theatre</li>
                <li><i class="fa-solid fa-hospital w-6 text-bright-cyan"></i> Emory Hospital Midtown</li>
                <li><i class="fa-solid fa-graduation-cap w-6 text-teal-glow"></i> Georgia Tech & GSU</li>
                <li><i class="fa-solid fa-building w-6 text-electric-blue"></i> Renaissance Atlanta</li>
            </ul>
        </div>

        <!-- Get the Location -->
        <div>
            <h3 class="font-black mb-6 4xl:mb-10 text-white uppercase tracking-widest text-xs 3xl:text-base 4xl:text-2xl">Get the Location</h3>
            <ul class="space-y-4 4xl:space-y-8 text-sm 3xl:text-xl 4xl:text-3xl text-gray-300 font-medium">
                <li class="flex items-start gap-3 4xl:gap-6">
                    <i class="fa-solid fa-location-dot mt-1 4xl:mt-2 text-teal-glow"></i>
                    <span>533 Peachtree St NE unit b<br>Atlanta, GA 30308</span>
                </li>
                <li class="flex items-center gap-3 4xl:gap-6">
                    <i class="fa-solid fa-phone text-teal-glow"></i>
                    <a href="tel:4708736088" class="hover:text-bright-cyan transition-colors font-bold">(470) 873-6088</a>
                </li>
                <li class="flex items-center gap-3 4xl:gap-6">
                    <i class="fa-solid fa-envelope text-teal-glow"></i>
                    <a href="mailto:untouchablesmoke533@gmail.com" class="hover:text-bright-cyan transition-colors">Email Us</a>
                </li>
            </ul>
        </div>
    </div>

    <!-- AI SECTION (FULL WIDTH) -->
    <div class="max-w-[1800px] 4xl:max-w-[2400px] mx-auto bg-white/5 border border-white/10 rounded-3xl p-8 3xl:p-12 4xl:p-16 mb-20 4xl:mb-32 relative z-10 backdrop-blur-sm">
        <div class="flex flex-col lg:flex-row items-center justify-between gap-8">
            <div class="text-center lg:text-left max-w-2xl">
                <h3 class="font-black mb-2 4xl:mb-4 text-white uppercase tracking-widest text-lg 3xl:text-2xl 4xl:text-4xl">Ask Your AI About Us</h3>
                <p class="text-gray-400 text-sm 3xl:text-xl 4xl:text-3xl leading-relaxed">Curious about our selection or prices? Click a logo to automatically ask your favorite AI about Untouchable Smoke Shop.</p>
            </div>
            <div class="flex flex-wrap justify-center lg:justify-end gap-3 4xl:gap-5 w-full lg:w-auto">
                {aiLinks.map(ai => (
                    <a 
                        href={ai.url} 
                        target="_blank" 
                        rel="noopener noreferrer"
                        id={ai.id}
                        class={`flex items-center justify-center sm:justify-start gap-3 4xl:gap-5 px-4 py-3 4xl:px-8 4xl:py-5 rounded-xl border ${ai.color} hover:opacity-90 hover:-translate-y-1 transition-all shadow-lg w-full sm:w-[160px] 3xl:w-[220px] 4xl:w-[280px]`}
                        aria-label={`Ask ${ai.name} about us`}
                    >
                        <i class={`${ai.icon} text-xl 3xl:text-3xl 4xl:text-5xl w-6 3xl:w-8 4xl:w-10 text-center`}></i>
                        <span class="font-bold text-sm 3xl:text-xl 4xl:text-3xl tracking-wide">{ai.name}</span>
                    </a>
                ))}
            </div>
        </div>
    </div>

    <!-- COPYRIGHT -->
    <div class="max-w-[1800px] 4xl:max-w-[2400px] mx-auto pt-10 4xl:pt-16 border-t border-white/5 text-center text-[10px] 3xl:text-sm 4xl:text-xl text-gray-400 font-bold uppercase tracking-widest">
        <p>&copy; 2026 Untouchable Smoke Shop. Powered by <a href="https://www.sayitaintseo.com" target="_blank" rel="noopener" class="text-gray-300 hover:text-bright-cyan transition-colors underline underline-offset-4 decoration-teal-glow/30">Say It Ain't SEO</a>.</p>
    </div>

    <!-- Toast Notification -->
    <div id="copy-toast" class="fixed bottom-10 left-1/2 -translate-x-1/2 bg-bright-cyan text-deep-black px-6 py-3 rounded-full font-bold uppercase tracking-widest shadow-2xl transition-all duration-300 transform translate-y-20 opacity-0 z-[100] pointer-events-none flex items-center gap-3">
        <i class="fa-solid fa-check-circle text-xl"></i>
        <span>Prompt copied! Paste in Gemini.</span>
    </div>
</footer>

<script define:vars={{ promptText: aiPrompt.trim() }}>
    const geminiLink = document.getElementById('gemini-ai-link');
    const toast = document.getElementById('copy-toast');
    
    if (geminiLink && toast) {
        geminiLink.addEventListener('click', (e) => {
            navigator.clipboard.writeText(promptText).then(() => {
                toast.classList.remove('translate-y-20', 'opacity-0');
                setTimeout(() => {
                    toast.classList.add('translate-y-20', 'opacity-0');
                }, 3000);
            }).catch(err => {
                console.error('Failed to copy prompt: ', err);
            });
        });
    }
</script>
