---
import { getCollection } from 'astro:content';
import SectionHeader from '../ui/SectionHeader.astro';
import { formatDate } from '../../lib/utils';

const allEvents = await getCollection('events');
// Get a larger batch of upcoming events at build time so the client has a buffer
const upcomingEvents = allEvents
  .filter(event => event.data.date >= new Date(Date.now() - 86400000 * 2)) // Buffer of 2 days in the past to account for timezones
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf())
  .slice(0, 10);

const colors = ['text-purple-300', 'text-teal-300', 'text-cyan-300'];
const bgColors = ['bg-purple-vibe/20', 'bg-teal-glow/20', 'bg-bright-cyan/20'];
const borderColors = ['border-purple-vibe/30', 'border-teal-glow/30', 'border-bright-cyan/30'];
---
<section id="calendar" class="py-20 3xl:py-40 4xl:py-56 px-6 max-w-[1800px] 4xl:max-w-[2400px] mx-auto">
    <div class="bg-charcoal/50 rounded-[40px] 4xl:rounded-[60px] border border-white/5 overflow-hidden">
        <div class="p-8 md:p-12 3xl:p-20 4xl:p-28 border-b border-white/5 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
            <SectionHeader title="Loveland" accentText="Local Events" accentColor="text-gv-green" subtitle="Upcoming events and drops." />
            <div class="flex flex-col gap-4">
                <a href="/loveland-events" class="vibe-gradient px-6 py-3 4xl:px-10 4xl:py-6 rounded-full text-sm 4xl:text-2xl font-bold uppercase tracking-widest hover:scale-105 transition-transform text-white text-center">
                    See the Lineup
                </a>
                <a href="sms:+19706198002?body=I'm%20interested%20in%20collaborating%20on%20an%20event!" class="glass-morphism px-6 py-3 4xl:px-10 4xl:py-6 rounded-full text-sm 4xl:text-2xl font-bold uppercase tracking-widest hover:bg-white/10 transition-colors flex items-center gap-2 4xl:gap-4 justify-center">
                    <i class="fa-solid fa-comment-sms text-gv-green"></i> Pitch an Event
                </a>
            </div>
        </div>
        
        <div class="flex flex-col" id="pulse-events-container">
            {upcomingEvents.map((event, index) => {
                const colorIndex = index % colors.length;
                const d = new Date(event.data.date);
                const month = d.toLocaleDateString('en-US', { month: 'short', timeZone: 'UTC' });
                const day = d.toLocaleDateString('en-US', { day: '2-digit', timeZone: 'UTC' });
                
                return (
                    <a href={`/events/${event.slug}`} data-event-date={event.data.date.toISOString()} class="event-row group 4xl:p-12 hidden hover:bg-white/5 transition-colors">
                        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6 w-full">
                            <div class="flex items-center gap-6 4xl:gap-10 mb-4 md:mb-0">
                                <div class={`w-16 h-16 4xl:w-24 4xl:h-24 rounded-2xl 4xl:rounded-3xl ${bgColors[colorIndex]} ${colors[colorIndex]} flex flex-col items-center justify-center border ${borderColors[colorIndex]} shrink-0`}>
                                    <span class="text-xs 4xl:text-lg font-bold uppercase">{month}</span>
                                    <span class="text-xl 4xl:text-4xl font-black leading-none">{day}</span>
                                </div>
                                <div>
                                    <div class={`text-[10px] 4xl:text-base font-black ${colors[colorIndex]} uppercase tracking-widest mb-1 4xl:mb-2`}>{event.data.category}</div>
                                    <h3 class="text-xl md:text-2xl 4xl:text-5xl font-black uppercase group-hover:text-white transition-colors">{event.data.title}</h3>
                                </div>
                            </div>
                            <div class="flex items-center gap-6 4xl:gap-10 w-full md:w-auto justify-between md:justify-end">
                                <div class="text-sm 4xl:text-2xl text-gray-400 font-bold flex flex-col items-end gap-1">
                                    <span><i class="fa-solid fa-location-dot mr-2"></i>{event.data.venue}</span>
                                    {event.data.time && <span><i class="fa-regular fa-clock mr-2"></i>{event.data.time}</span>}
                                </div>
                                <div class="text-electric-blue group-hover:text-white transition-colors group-hover:translate-x-2 transform duration-300"><i class="fa-solid fa-arrow-right text-xl 4xl:text-4xl"></i></div>
                            </div>
                        </div>
                    </a>
                );
            })}
        </div>
    </div>
</section>

<script>
    function filterPulseEvents() {
        const rows = document.querySelectorAll('#pulse-events-container .event-row');
        const now = new Date();
        // Set to start of today in local time to keep events visible until the day is over
        now.setHours(0, 0, 0, 0); 

        let visibleCount = 0;
        rows.forEach(row => {
            const dateStr = row.getAttribute('data-event-date');
            if (!dateStr) return;
            
            const eventDate = new Date(dateStr);
            
            // If the event is today or in the future, and we haven't shown 3 yet
            if (eventDate >= now && visibleCount < 3) {
                row.classList.remove('hidden');
                row.classList.add('block');
                visibleCount++;
            } else {
                row.classList.add('hidden');
                row.classList.remove('block');
            }
        });
    }

    // Run immediately on load
    filterPulseEvents();
</script>
