---
import { getCollection } from 'astro:content';
import { formatDate } from '../../lib/utils';
import SectionHeader from '../ui/SectionHeader.astro';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const recentPosts = posts.slice(0, 3);
---

<section class="py-20 px-6 max-w-[1200px] mx-auto">
  <SectionHeader title="Latest from the Blog" subtitle="News, Guides & Culture" />
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
    {recentPosts.map(post => (
      <a href={`/blog/${post.slug}`} class="bg-charcoal/30 rounded-3xl p-6 border border-white/5 hover:border-bright-cyan/30 transition-colors group flex flex-col h-full">
        <div class="mb-4 text-sm text-gray-400 font-bold uppercase tracking-widest">
          {formatDate(post.data.date)}
        </div>
        <h3 class="text-xl font-black uppercase mb-3 group-hover:text-bright-cyan transition-colors line-clamp-2">
          {post.data.title}
        </h3>
        <p class="text-gray-400 mb-6 line-clamp-3 flex-grow">
          {post.data.description}
        </p>
        <div class="flex flex-wrap gap-2 mt-auto">
          {post.data.tags.slice(0, 3).map(tag => (
            <span class="text-xs font-bold uppercase tracking-widest text-teal-glow bg-teal-glow/10 px-2 py-1 rounded">
              #{tag}
            </span>
          ))}
        </div>
      </a>
    ))}
  </div>
  
  <div class="text-center mt-12">
    <a href="/blog" class="inline-block bg-white text-black py-3 px-8 rounded-full font-bold uppercase tracking-widest hover:bg-bright-cyan hover:text-white transition-colors">
      The Breakdown
    </a>
  </div>
</section>
