<header class="relative py-24 md:py-32 3xl:py-56 4xl:py-72 px-6 max-w-[2000px] 4xl:max-w-[3000px] mx-auto text-center overflow-hidden">
    <div class="glow-blur -top-20 -left-20 w-80 h-80 3xl:w-[600px] 3xl:h-[600px] 4xl:w-[800px] 4xl:h-[800px] bg-olive-glow animate-float"></div>
    <div class="glow-blur top-40 -right-20 w-96 h-96 3xl:w-[800px] 3xl:h-[800px] 4xl:w-[1200px] 4xl:h-[1200px] bg-green-glow opacity-10"></div>
    
    <h1 class="hero-title 4xl:text-[12rem] 4xl:leading-[0.85]">
