<header class="relative py-8 md:py-12 3xl:py-20 px-6 max-w-[2000px] 4xl:max-w-[3000px] mx-auto text-center overflow-hidden">
    <div class="glow-blur -top-20 -left-20 w-80 h-80 3xl:w-[600px] 3xl:h-[600px] 4xl:w-[800px] 4xl:h-[800px] bg-gv-blue animate-float"></div>
    <div class="glow-blur top-40 -right-20 w-96 h-96 3xl:w-[800px] 3xl:h-[800px] 4xl:w-[1200px] 4xl:h-[1200px] bg-gv-green opacity-10"></div>
    
    <div class="inline-block mb-4 md:mb-6 3xl:mb-8 4xl:mb-12 px-6 py-2 3xl:px-8 3xl:py-3 4xl:px-12 4xl:py-5 rounded-full border border-gv-green/30 bg-gv-green/10 text-gv-green font-bold tracking-widest uppercase text-xs 3xl:text-lg 4xl:text-2xl shadow-[0_0_15px_rgba(139,195,74,0.2)]">
        📍 100% Loveland Owned & Operated
    </div>

    <img src="/ll.webp" alt="Good Vibes Glass Art Logo" class="mx-auto w-48 md:w-64 mb-6" />

    <h1 class="hero-title 4xl:text-[11rem] 4xl:leading-[0.9] mb-4">
        EXCLUSIVE GLASS. <br><span class="text-gradient">KEEP IT LOCAL.</span>
    </h1>
    
    <p class="text-lg md:text-xl 3xl:text-3xl 4xl:text-5xl text-gray-300 max-w-3xl 3xl:max-w-5xl 4xl:max-w-7xl mx-auto mb-8 md:mb-10 3xl:mb-14 4xl:mb-20 font-medium leading-relaxed">
        Don't let out-of-town corporate chains take your money. Support your neighbors at Loveland's premier destination for high-end functional art, exclusive bongs, pipes, and <strong class="text-white border-b-2 border-gv-green">premium soil amendments</strong>. Expert curation and local expertise you can trust.
    </p>
    
    <div class="flex flex-wrap justify-center gap-4 3xl:gap-8 4xl:gap-12 w-full">
        <a href="#hot-list" class="vibe-gradient px-8 py-4 md:px-10 3xl:px-16 3xl:py-6 4xl:px-24 4xl:py-12 rounded-full font-black text-white text-[15px] md:text-lg 3xl:text-2xl 4xl:text-4xl hover:shadow-[0_0_30px_rgba(139,195,74,0.4)] shadow-xl transition-all hover:-translate-y-1">SEE THE COLLECTION</a>
        <a href="#optin" class="glass-morphism px-8 py-4 md:px-10 3xl:px-16 3xl:py-6 4xl:px-24 4xl:py-12 rounded-full font-black text-[15px] md:text-lg 3xl:text-2xl 4xl:text-4xl border border-white/10 uppercase tracking-wider hover:bg-white/10 hover:border-gv-green/50 transition-all text-gv-green">JOIN THE INNER CIRCLE</a>
    </div>
</header>
