---
import SectionHeader from '../ui/SectionHeader.astro';
---
<section id="hot-list" class="py-20 3xl:py-40 4xl:py-56 px-6 max-w-[1800px] 4xl:max-w-[2400px] mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 3xl:mb-24 4xl:mb-32 gap-6">
        <SectionHeader title="The" accentText="Hot List" accentColor="text-purple-vibe" subtitle="What's trending at 533 Peachtree right now." />
        <div class="flex gap-2 4xl:gap-4 overflow-x-auto pb-2 w-full md:w-auto" id="category-filters">
            <button class="category-pill active 4xl:text-2xl 4xl:px-8 4xl:py-4" data-filter="all">All</button>
            <button class="category-pill 4xl:text-2xl 4xl:px-8 4xl:py-4" data-filter="vapes">Vapes</button>
            <button class="category-pill 4xl:text-2xl 4xl:px-8 4xl:py-4" data-filter="glass">Glass</button>
        </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 3xl:gap-12 4xl:gap-16" id="product-grid">
        <!-- Product 1 -->
        <article class="hot-card group 4xl:p-12" data-category="vapes">
            <div class="absolute top-6 right-6 4xl:top-8 4xl:right-8 bg-teal-glow text-deep-black text-[10px] 4xl:text-sm font-black px-3 py-1 4xl:px-5 4xl:py-2 rounded-full uppercase tracking-widest animate-pulse">In Stock</div>
            <div class="text-teal-glow text-3xl 3xl:text-5xl 4xl:text-7xl mb-6 4xl:mb-10"><i class="fa-solid fa-bolt"></i></div>
            <h3 class="text-2xl 3xl:text-4xl 4xl:text-6xl font-black mb-2 4xl:mb-4 uppercase">Geek Bar Pulse</h3>
            <p class="text-gray-400 text-sm 3xl:text-xl 4xl:text-3xl mb-6 4xl:mb-10">The most requested disposable in ATL. Dual mesh coil, full screen display.</p>
            <div class="flex justify-between items-center mt-auto">
                <span class="text-xl 3xl:text-3xl 4xl:text-5xl font-black text-white">$24.99</span>
                <button class="text-xs 3xl:text-lg 4xl:text-2xl font-bold uppercase tracking-widest text-white hover:text-teal-glow transition-colors">The Breakdown <i class="fa-solid fa-arrow-right ml-1"></i></button>
            </div>
        </article>

        <!-- Product 2 -->
        <article class="hot-card group 4xl:p-12" data-category="glass">
            <div class="absolute top-6 right-6 4xl:top-8 4xl:right-8 bg-purple-vibe text-deep-black text-[10px] 4xl:text-sm font-black px-3 py-1 4xl:px-5 4xl:py-2 rounded-full uppercase tracking-widest">New</div>
            <div class="text-purple-vibe text-3xl 3xl:text-5xl 4xl:text-7xl mb-6 4xl:mb-10"><i class="fa-solid fa-fire"></i></div>
            <h3 class="text-2xl 3xl:text-4xl 4xl:text-6xl font-black mb-2 4xl:mb-4 uppercase">Artisan Beakers</h3>
            <p class="text-gray-400 text-sm 3xl:text-xl 4xl:text-3xl mb-6 4xl:mb-10">Hand-blown, thick glass. Perfect for your daily driver.</p>
            <div class="flex justify-between items-center mt-auto">
                <span class="text-xl 3xl:text-3xl 4xl:text-5xl font-black text-white">From $45</span>
                <button class="text-xs 3xl:text-lg 4xl:text-2xl font-bold uppercase tracking-widest text-white hover:text-purple-400 transition-colors">The Breakdown <i class="fa-solid fa-arrow-right ml-1"></i></button>
            </div>
        </article>

        <!-- Product 3 -->
        <article class="hot-card group 4xl:p-12" data-category="vapes">
            <div class="absolute top-6 right-6 4xl:top-8 4xl:right-8 bg-red-600 text-white text-[10px] 4xl:text-sm font-black px-3 py-1 4xl:px-5 4xl:py-2 rounded-full uppercase tracking-widest animate-pulse">Low Stock</div>
            <div class="text-red-500 text-3xl 3xl:text-5xl 4xl:text-7xl mb-6 4xl:mb-10"><i class="fa-solid fa-wind"></i></div>
            <h3 class="text-2xl 3xl:text-4xl 4xl:text-6xl font-black mb-2 4xl:mb-4 uppercase">Lost Mary MT15000</h3>
            <p class="text-gray-400 text-sm 3xl:text-xl 4xl:text-3xl mb-6 4xl:mb-10">Turbo mode enabled. Selling out fast this weekend.</p>
            <div class="flex justify-between items-center mt-auto">
                <span class="text-xl 3xl:text-3xl 4xl:text-5xl font-black text-white">$22.99</span>
                <button class="text-xs 3xl:text-lg 4xl:text-2xl font-bold uppercase tracking-widest text-white hover:text-red-400 transition-colors">Get Notified <i class="fa-solid fa-bell ml-1"></i></button>
            </div>
        </article>
    </div>
</section>

<script>
    // Category Filtering
    const filterBtns = document.querySelectorAll('.category-pill');
    const products = document.querySelectorAll('.hot-card');

    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            filterBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            
            const filter = btn.getAttribute('data-filter');
            
            products.forEach(product => {
                const el = product as HTMLElement;
                if (filter === 'all' || el.getAttribute('data-category') === filter) {
                    el.style.display = 'block';
                    setTimeout(() => {
                        el.style.opacity = '1';
                        el.style.transform = 'translateY(0)';
                    }, 50);
                } else {
                    el.style.opacity = '0';
                    el.style.transform = 'translateY(20px)';
                    setTimeout(() => {
                        el.style.display = 'none';
                    }, 300);
                }
            });
        });
    });
</script>
