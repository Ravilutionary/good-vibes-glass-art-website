---
import SectionHeader from '../ui/SectionHeader.astro';
---
<section id="reviews" class="bg-charcoal/30 py-24 3xl:py-48 4xl:py-64 px-6 relative">
    <div class="glow-blur absolute inset-0 bg-olive-glow opacity-5 animate-pulse-slow"></div>
    <div class="max-w-[1800px] 4xl:max-w-[2400px] mx-auto relative z-10">
        <div class="mb-12 3xl:mb-24 4xl:mb-32">
            <SectionHeader title="Trusted by the" accentText="City" accentColor="text-bright-cyan" alignment="center" />
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 3xl:gap-12 4xl:gap-16">
            <figure class="glass-morphism p-6 3xl:p-12 4xl:p-16 rounded-2xl 4xl:rounded-3xl hover:-translate-y-2">
                <div class="flex text-teal-glow mb-4 4xl:mb-8 text-xs 3xl:text-lg 4xl:text-2xl"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                <blockquote class="text-sm 3xl:text-xl 4xl:text-3xl italic mb-4 4xl:mb-8 text-gray-300">"Hikeen is so sweet and very attentive! They’re so friendly and have amazing prices!"</blockquote>
                <figcaption class="text-xs 3xl:text-sm 4xl:text-xl font-bold uppercase tracking-widest text-bright-cyan">— Jaden Droge</figcaption>
            </figure>
            <figure class="glass-morphism p-6 3xl:p-12 4xl:p-16 rounded-2xl 4xl:rounded-3xl border-bright-cyan/20 hover:-translate-y-2">
                <div class="flex text-bright-cyan mb-4 4xl:mb-8 text-xs 3xl:text-lg 4xl:text-2xl"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                <blockquote class="text-sm 3xl:text-xl 4xl:text-3xl italic mb-4 4xl:mb-8 text-gray-300">"BEST PRICES IN ATLANTA THANKS FOR THE BEST PRICES. Very clean and amazing atmosphere!!"</blockquote>
                <figcaption class="text-xs 3xl:text-sm 4xl:text-xl font-bold uppercase tracking-widest text-bright-cyan">— Tyreak Muhammad</figcaption>
            </figure>
            <figure class="glass-morphism p-6 3xl:p-12 4xl:p-16 rounded-2xl 4xl:rounded-3xl hover:-translate-y-2">
                <div class="flex text-teal-glow mb-4 4xl:mb-8 text-xs 3xl:text-lg 4xl:text-2xl"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></div>
                <blockquote class="text-sm 3xl:text-xl 4xl:text-3xl italic mb-4 4xl:mb-8 text-gray-300">"Customer Service was very embracing I will continue to Shop due to reasonable prices."</blockquote>
                <figcaption class="text-xs 3xl:text-sm 4xl:text-xl font-bold uppercase tracking-widest text-bright-cyan">— Thomas Scott</figcaption>
            </figure>
        </div>
    </div>
</section>
