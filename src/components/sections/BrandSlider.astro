---
import { getCollection } from 'astro:content';

const brands = await getCollection('brands');
---

<section class="py-4 md:py-6 border-y border-white/5 bg-black/40 overflow-hidden relative" aria-label="Brands we carry">
    <!-- Gradient Overlays for smooth fade effect on the left and right edges -->
    <div class="absolute inset-y-0 left-0 w-16 md:w-48 bg-gradient-to-r from-deep-black to-transparent z-10 pointer-events-none"></div>
    <div class="absolute inset-y-0 right-0 w-16 md:w-48 bg-gradient-to-l from-deep-black to-transparent z-10 pointer-events-none"></div>
    
    <div class="flex whitespace-nowrap animate-marquee items-center w-max py-4 will-change-transform">
        <!-- Triplicated content for seamless infinite scrolling -->
        {Array(3).fill(0).map(() => (
            <div class="flex items-center justify-around px-4 md:px-8 gap-6 md:gap-10">
                {brands.map(brand => (
                    <div class="flex items-center justify-center w-32 h-16 md:w-48 md:h-24 cursor-pointer group p-2 md:p-4 hover:-translate-y-1 transition-all duration-300">
                        <img 
                            src={brand.data.logo} 
                            alt={brand.data.name} 
                            class="w-full h-full object-contain brightness-0 invert opacity-70 group-hover:opacity-100 group-hover:drop-shadow-[0_0_15px_rgba(30,149,212,0.8)] transition-all duration-300" 
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                ))}
            </div>
        ))}
    </div>
</section>
