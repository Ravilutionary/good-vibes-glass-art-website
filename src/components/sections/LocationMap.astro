---
import SectionHeader from '../ui/SectionHeader.astro';
---
<section id="location-map" class="py-20 3xl:py-40 4xl:py-56 px-6 max-w-[1800px] 4xl:max-w-[2400px] mx-auto overflow-hidden">
    <div class="grid lg:grid-cols-2 gap-12 3xl:gap-24 4xl:gap-32 items-center">
        <div class="space-y-8 4xl:space-y-12">
            <SectionHeader title="Pull Up to" accentText="Peachtree" accentColor="text-bright-cyan" subtitle="Located in the heart of Atlanta. Look for the neon glow at 533 Peachtree St NE. We're the premier destination for the city's premium smoke needs." />
            
            <div class="flex flex-col sm:flex-row gap-4 4xl:gap-8">
                <a href="https://maps.app.goo.gl/DBnPu5MiW5beXzQg4" target="_blank" rel="noopener noreferrer" class="vibe-gradient px-8 py-5 4xl:px-12 4xl:py-8 rounded-2xl 4xl:rounded-3xl font-black text-white text-center hover:scale-105 transition-all shadow-lg flex-1 flex items-center justify-center gap-3 4xl:gap-6 text-lg 3xl:text-2xl 4xl:text-4xl">
                    <i class="fa-solid fa-diamond-turn-right"></i> GET THE LOCATION
                </a>
                <button id="copy-address-btn" class="bg-white/5 border border-white/10 px-8 py-5 4xl:px-12 4xl:py-8 rounded-2xl 4xl:rounded-3xl font-black text-white text-center hover:bg-white/10 transition-all shadow-lg flex-1 flex items-center justify-center gap-3 4xl:gap-6 text-lg 3xl:text-2xl 4xl:text-4xl">
                    <i class="fa-solid fa-copy"></i> COPY ADDRESS
                </button>
            </div>

            <div class="flex gap-4 items-center text-gray-400 font-bold uppercase tracking-widest text-xs 3xl:text-lg 4xl:text-2xl">
                <i class="fa-solid fa-clock text-teal-glow"></i> Open until Midnight (2AM Weekends)
            </div>
        </div>

        <div class="relative aspect-video lg:aspect-square rounded-[40px] 4xl:rounded-[60px] overflow-hidden border border-white/10 shadow-2xl shadow-teal-glow/5 group">
            <iframe 
                src="https://maps.google.com/maps?q=Untouchable%20Smoke%20Shop,%20533%20Peachtree%20St%20NE,%20Atlanta,%20GA%2030308&t=&z=17&ie=UTF8&iwloc=&output=embed" 
                width="100%" 
                height="100%" 
                style="border:0;" 
                allowfullscreen="" 
                loading="eager" 
                referrerpolicy="no-referrer" 
                title="Google Maps location of Untouchable Smoke Shop"
                class="w-full h-full"
            ></iframe>
        </div>
    </div>

    <!-- Toast Notification for Copy -->
    <div id="map-copy-toast" class="fixed bottom-10 left-1/2 -translate-x-1/2 bg-bright-cyan text-deep-black px-6 py-3 rounded-full font-bold uppercase tracking-widest shadow-2xl transition-all duration-300 transform translate-y-20 opacity-0 z-[100] pointer-events-none flex items-center gap-3">
        <i class="fa-solid fa-check-circle text-xl"></i>
        <span>Address copied!</span>
    </div>
</section>

<script>
    const copyBtn = document.getElementById('copy-address-btn');
    const toast = document.getElementById('map-copy-toast');
    const address = "533 Peachtree St NE unit b, Atlanta, GA 30308";

    if (copyBtn && toast) {
        copyBtn.addEventListener('click', () => {
            navigator.clipboard.writeText(address).then(() => {
                toast.classList.remove('translate-y-20', 'opacity-0');
                setTimeout(() => {
                    toast.classList.add('translate-y-20', 'opacity-0');
                }, 3000);
            }).catch(err => {
                console.error('Failed to copy: ', err);
            });
        });
    }
</script>
