---
import SectionHeader from './SectionHeader.astro';

interface Props {
    title: string;
    subtitle: string;
    description: string;
    accentColor?: string;
}

const { title, subtitle, description, accentColor = "text-teal-glow" } = Astro.props;
---
<section class="pt-40 pb-20 3xl:pt-60 3xl:pb-32 4xl:pt-80 4xl:pb-40 px-6 relative overflow-hidden">
    <div class="glow-blur top-20 left-10 w-96 h-96 3xl:w-[800px] 3xl:h-[800px] 4xl:w-[1200px] 4xl:h-[1200px] bg-purple-vibe !opacity-20"></div>
    <div class="max-w-[1800px] 4xl:max-w-[2400px] mx-auto relative z-10 text-center">
        <h1 class="text-5xl md:text-7xl 3xl:text-9xl 4xl:text-[12rem] font-black tracking-tighter uppercase mb-6 4xl:mb-12">
            {title}
        </h1>
        <h2 class={`text-xl md:text-3xl 3xl:text-5xl 4xl:text-7xl font-bold uppercase tracking-widest mb-8 4xl:mb-16 ${accentColor}`}>
            {subtitle}
        </h2>
        <p class="text-lg md:text-xl 3xl:text-3xl 4xl:text-5xl text-gray-300 max-w-3xl 3xl:max-w-5xl 4xl:max-w-7xl mx-auto font-medium leading-relaxed">
            {description}
        </p>
    </div>
</section>
