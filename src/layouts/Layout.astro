---
interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Open Graph / Social Meta Tags -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://goodvibesglassart.com/" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/ll.webp" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://goodvibesglassart.com/" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content="/ll.webp" />
		
		<!-- PERFORMANCE: Resource Hints -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link rel="preconnect" href="https://cdnjs.cloudflare.com">
		
		<!-- Preload Critical Font -->
		<link rel="preload" href="https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7W0Q5nw.woff2" as="font" type="font/woff2" crossorigin>

		<!-- Google Fonts (Synchronous for LCP) -->
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Eczar:wght@400;500;600;700;800&display=swap">
		
		<!-- Defer FontAwesome to prevent render blocking -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" media="print" onload="this.media='all'">
		<noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"></noscript>

		<!-- DYNAMIC LOCATION SCHEMA -->
		<script type="application/ld+json" is:inline>
		{
		  "@context": "https://schema.org",
		  "@type": "SmokeShop",
		  "name": "Good Vibes Glass Art",
		  "image": "/ll.webp",
		  "telephone": "+1-970-619-8002",
		  "url": "https://goodvibesglassart.com/",
		  "address": {
			"@type": "PostalAddress",
			"streetAddress": "1421 N Cleveland Ave",
			"addressLocality": "Loveland",
			"addressRegion": "CO",
			"postalCode": "80538",
			"addressCountry": "US"
		  },
		  "geo": {
			"@type": "GeoCoordinates",
			"latitude": 40.407835,
			"longitude": -105.074929
		  },
		  "openingHoursSpecification": [
			{ "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"], "opens": "09:00", "closes": "21:00" },
			{ "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "10:00", "closes": "20:00" }
		  ],
		  "areaServed": { "@type": "City", "name": "Loveland" }
		}
		</script>

		<!-- AGE GATE CHECK (Run immediately to prevent flashing) -->
		<script is:inline>
			(function() {
				const STORE_CONFIG = {
					id: 'good_vibes_v1',
					phone: '9706198002'
				};
				const storedData = localStorage.getItem(`${STORE_CONFIG.id}_verified`);
				let isVerified = false;
				if (storedData) {
					try {
						const parsed = JSON.parse(storedData);
						if (parsed.verified && parsed.expiry > new Date().getTime()) {
							isVerified = true;
						}
					} catch (e) {
						if (storedData === 'true') isVerified = true;
					}
				}
				if (isVerified) {
					document.documentElement.classList.add('age-verified');
				} else {
					document.documentElement.classList.add('age-unverified');
				}
			})();
		</script>
	</head>
	<body class="bg-gv-black text-white overflow-x-hidden antialiased selection:bg-gv-green selection:text-gv-black font-sans">
		<slot />
	</body>
</html>

<style is:global>
	@tailwind base;
	@tailwind components;
	@tailwind utilities;

	@layer components {
		.glass-morphism {
			@apply bg-gv-blue/60 backdrop-blur-xl border border-white/10 transition-all duration-300;
		}
		.vibe-gradient {
			@apply bg-gradient-to-br from-gv-blue via-gv-green to-gv-yellow;
		}
		.text-gradient {
			@apply bg-gradient-to-r from-gv-green to-gv-yellow bg-clip-text text-transparent;
		}
		.glow-blur {
			@apply absolute rounded-full opacity-15 blur-[120px] pointer-events-none;
		}
		.nav-link {
			@apply hover:text-white transition-colors text-sm md:text-base 3xl:text-lg font-medium;
		}
		.hero-title {
			font-size: clamp(2.25rem, 6.5vw, 8rem);
			@apply font-display font-black tracking-tight leading-[0.9] mb-4;
		}
		.hot-card {
			@apply bg-gv-black/80 rounded-3xl p-6 3xl:p-10 border border-white/5 hover:border-gv-green/50 transition-all hover:-translate-y-2 relative overflow-hidden;
		}
		.category-pill {
			@apply px-6 py-2 rounded-full text-sm font-bold uppercase tracking-widest border border-white/10 hover:bg-white/10 transition-colors cursor-pointer;
		}
		.category-pill.active {
			@apply bg-white text-black border-white;
		}
		.event-row {
			@apply flex flex-col md:flex-row items-start md:items-center justify-between p-6 3xl:p-10 border-b border-white/5 hover:bg-white/5 transition-colors;
		}
	}
	
	/* Age Gate Display Logic */
	html.age-verified #age-gate {
		display: none !important;
	}
	html.age-unverified body {
		overflow: hidden !important;
	}

	#age-gate { transition: opacity 0.5s ease; }
	
	:focus-visible {
		@apply outline-none ring-2 ring-gv-green ring-offset-4 ring-offset-gv-black;
	}

	.error-shake {
		animation: shake 0.4s ease-in-out;
		@apply border-red-500 !important;
	}

	@keyframes shake {
		0%, 100% { transform: translateX(0); }
		25% { transform: translateX(-5px); }
		75% { transform: translateX(5px); }
	}



	/* Map Styles */
	.map-frame {
		@apply grayscale invert contrast-125 opacity-80 transition-all duration-700 hover:grayscale-0 hover:invert-0 hover:opacity-100;
	}

	/* Hide scrollbar for horizontal scrolling elements */
	.no-scrollbar::-webkit-scrollbar {
		display: none;
	}
	.no-scrollbar {
		-ms-overflow-style: none;  /* IE and Edge */
		scrollbar-width: none;  /* Firefox */
	}
</style>
